<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="nl2sql.safe">

    <!--
        Safe query execution for pre-validated SELECT statements.
        SQL must be validated by isSqlSafe() before calling this mapper.
        Uses parameterized LIMIT to prevent injection through limit parameter.
    -->
    <select id="executeWithLimit" resultType="java.util.HashMap">
        ${sql} LIMIT #{limit}
    </select>

    <!-- Simple safe execution without limit parameter (uses default) -->
    <select id="execute" resultType="java.util.HashMap">
        ${sql}
    </select>

</mapper>
