<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.operator.nl2sql.repository.SiteSummaryMapper">

    <resultMap id="SiteSummaryResultMap" type="com.operator.nl2sql.entity.SiteSummary">
        <id property="id" column="id"/>
        <result property="operatorId" column="operator_id"/>
        <result property="dataMonth" column="data_month"/>
        <result property="lte700MSite" column="lte_700M_site"/>
        <result property="lte700MCell" column="lte_700M_cell"/>
        <result property="lte800MSite" column="lte_800M_site"/>
        <result property="lte800MCell" column="lte_800M_cell"/>
        <result property="lte900MSite" column="lte_900M_site"/>
        <result property="lte900MCell" column="lte_900M_cell"/>
        <result property="lte1400MSite" column="lte_1400M_site"/>
        <result property="lte1400MCell" column="lte_1400M_cell"/>
        <result property="lte1800MSite" column="lte_1800M_site"/>
        <result property="lte1800MCell" column="lte_1800M_cell"/>
        <result property="lte2100MSite" column="lte_2100M_site"/>
        <result property="lte2100MCell" column="lte_2100M_cell"/>
        <result property="lte2600MSite" column="lte_2600M_site"/>
        <result property="lte2600MCell" column="lte_2600M_cell"/>
        <result property="nr700MSite" column="nr_700M_site"/>
        <result property="nr700MCell" column="nr_700M_cell"/>
        <result property="nr800MSite" column="nr_800M_site"/>
        <result property="nr800MCell" column="nr_800M_cell"/>
        <result property="nr900MSite" column="nr_900M_site"/>
        <result property="nr900MCell" column="nr_900M_cell"/>
        <result property="nr1400MSite" column="nr_1400M_site"/>
        <result property="nr1400MCell" column="nr_1400M_cell"/>
        <result property="nr1800MSite" column="nr_1800M_site"/>
        <result property="nr1800MCell" column="nr_1800M_cell"/>
        <result property="nr2100MSite" column="nr_2100M_site"/>
        <result property="nr2100MCell" column="nr_2100M_cell"/>
        <result property="nr2600MSite" column="nr_2600M_site"/>
        <result property="nr2600MCell" column="nr_2600M_cell"/>
        <result property="nr3500MSite" column="nr_3500M_site"/>
        <result property="nr3500MCell" column="nr_3500M_cell"/>
        <result property="nr4900MSite" column="nr_4900M_site"/>
        <result property="nr4900MCell" column="nr_4900M_cell"/>
        <result property="nr2300MSite" column="nr_2300M_site"/>
        <result property="nr2300MCell" column="nr_2300M_cell"/>
        <result property="lteTotalSite" column="lte_total_site"/>
        <result property="lteTotalCell" column="lte_total_cell"/>
        <result property="nrTotalSite" column="nr_total_site"/>
        <result property="nrTotalCell" column="nr_total_cell"/>
        <result property="totalSite" column="total_site"/>
        <result property="totalCell" column="total_cell"/>
        <result property="createdTime" column="created_time"/>
        <result property="updatedTime" column="updated_time"/>
    </resultMap>

    <select id="findAllLatest" resultMap="SiteSummaryResultMap">
        SELECT s.* FROM site_summary s
        WHERE s.data_month = (
            SELECT MAX(s2.data_month)
            FROM site_summary s2
            WHERE s2.operator_id = s.operator_id
        )
        ORDER BY s.operator_id
    </select>

    <select id="findLatestByOperatorId" resultMap="SiteSummaryResultMap">
        SELECT s.* FROM site_summary s
        WHERE s.operator_id = #{operatorId}
          AND s.data_month = (
            SELECT MAX(s2.data_month)
            FROM site_summary s2
            WHERE s2.operator_id = #{operatorId}
        )
    </select>

    <select id="findHistoryByOperatorId" resultMap="SiteSummaryResultMap">
        SELECT s.* FROM site_summary s
        WHERE s.operator_id = #{operatorId}
        ORDER BY s.data_month DESC
    </select>

    <select id="findByDataMonth" resultMap="SiteSummaryResultMap">
        SELECT s.* FROM site_summary s
        WHERE s.data_month = #{dataMonth}
        ORDER BY s.operator_id
    </select>

    <select id="findByOperatorIdAndMonth" resultMap="SiteSummaryResultMap">
        SELECT s.* FROM site_summary s
        WHERE s.operator_id = #{operatorId}
          AND s.data_month = #{dataMonth}
    </select>

</mapper>