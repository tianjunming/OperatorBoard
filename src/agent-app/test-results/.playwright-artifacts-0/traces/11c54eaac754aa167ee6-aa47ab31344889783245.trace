{"type":"frame-snapshot","snapshot":{"callId":"call@8","snapshotName":"after@call@8","pageId":"page@a6eae97871478571354dcacfa7aedd13","frameId":"frame@d7dff7750a971a8e8ea4032f4a3866c3","frameUrl":"http://localhost:3000/","doctype":"html","html":["HTML",{"lang":"zh-CN","data-theme":"light"},["HEAD",{},["BASE",{"href":"http://localhost:3000/"}],"\n    ","\n\n    ","\n\n    ",["META",{"charset":"utf-8"}],"\n    ",["META",{"name":"viewport","content":"width=device-width, initial-scale=1.0"}],"\n    ",["TITLE",{},"Operator Agent"],"\n  ",["STYLE",{},"/* SettingsModal.css - Settings Dialog Styles */\n\n.settings-modal {\n  position: fixed;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  width: 90%;\n  max-width: 700px;\n  max-height: 85vh;\n  background: var(--bg-primary);\n  border-radius: var(--radius-xl);\n  box-shadow: var(--shadow-xl);\n  z-index: var(--z-modal);\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n  animation: scaleIn var(--transition-base) ease-out;\n}\n\n.settings-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: var(--space-lg) var(--space-xl);\n  border-bottom: 1px solid var(--border-light);\n  flex-shrink: 0;\n}\n\n.settings-header h2 {\n  font-size: var(--font-size-lg);\n  font-weight: var(--font-weight-semibold);\n  color: var(--text-primary);\n}\n\n.settings-close {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 32px;\n  height: 32px;\n  border-radius: var(--radius-md);\n  color: var(--text-tertiary);\n  transition: all var(--transition-fast);\n}\n\n.settings-close:hover {\n  background: var(--bg-hover);\n  color: var(--text-primary);\n}\n\n.settings-body {\n  display: flex;\n  flex: 1;\n  min-height: 0;\n  overflow: hidden;\n}\n\n/* Settings Navigation */\n.settings-nav {\n  width: 180px;\n  padding: var(--space-lg);\n  border-right: 1px solid var(--border-light);\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-xs);\n  flex-shrink: 0;\n}\n\n.settings-nav-item {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-sm) var(--space-md);\n  border-radius: var(--radius-md);\n  font-size: var(--font-size-sm);\n  color: var(--text-secondary);\n  transition: all var(--transition-fast);\n  text-align: left;\n}\n\n.settings-nav-item:hover {\n  background: var(--bg-hover);\n  color: var(--text-primary);\n}\n\n.settings-nav-item.active {\n  background: var(--color-primary-light);\n  color: var(--color-primary);\n  font-weight: var(--font-weight-medium);\n}\n\n/* Settings Content */\n.settings-content {\n  flex: 1;\n  padding: var(--space-xl);\n  overflow-y: auto;\n}\n\n.settings-section h3 {\n  font-size: var(--font-size-base);\n  font-weight: var(--font-weight-semibold);\n  color: var(--text-primary);\n  margin-bottom: var(--space-xs);\n}\n\n.settings-description {\n  font-size: var(--font-size-sm);\n  color: var(--text-tertiary);\n  margin-bottom: var(--space-lg);\n}\n\n/* Theme Options */\n.theme-options {\n  display: flex;\n  gap: var(--space-md);\n}\n\n.theme-option {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-lg);\n  background: var(--bg-secondary);\n  border: 2px solid var(--border-light);\n  border-radius: var(--radius-lg);\n  min-width: 100px;\n  transition: all var(--transition-fast);\n}\n\n.theme-option:hover {\n  border-color: var(--border-default);\n  background: var(--bg-hover);\n}\n\n.theme-option.active {\n  border-color: var(--color-primary);\n  background: var(--color-primary-light);\n}\n\n.theme-icon {\n  width: 40px;\n  height: 40px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: var(--bg-primary);\n  border-radius: var(--radius-full);\n  color: var(--text-secondary);\n}\n\n.theme-option.active .theme-icon {\n  background: var(--color-primary);\n  color: white;\n}\n\n/* Font Size Options */\n.font-size-options {\n  display: flex;\n  gap: var(--space-sm);\n}\n\n.font-size-option {\n  padding: var(--space-sm) var(--space-xl);\n  background: var(--bg-secondary);\n  border: 2px solid var(--border-light);\n  border-radius: var(--radius-md);\n  font-size: var(--font-size-sm);\n  transition: all var(--transition-fast);\n}\n\n.font-size-option:hover {\n  border-color: var(--border-default);\n}\n\n.font-size-option.active {\n  border-color: var(--color-primary);\n  background: var(--color-primary-light);\n  color: var(--color-primary);\n}\n\n/* Shortcuts List */\n.shortcuts-list {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-sm);\n}\n\n.shortcut-item {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: var(--space-md);\n  background: var(--bg-secondary);\n  border-radius: var(--radius-md);\n}\n\n.shortcut-action {\n  font-size: var(--font-size-sm);\n  color: var(--text-primary);\n}\n\n.shortcut-keys {\n  display: flex;\n  gap: var(--space-xs);\n}\n\n.shortcut-key {\n  padding: var(--space-xs) var(--space-sm);\n  background: var(--bg-primary);\n  border: 1px solid var(--border-default);\n  border-radius: var(--radius-sm);\n  font-size: var(--font-size-xs);\n  font-family: var(--font-mono);\n  color: var(--text-secondary);\n}\n\n/* Toggle List */\n.toggle-list {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-md);\n}\n\n.toggle-item {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: var(--space-md);\n  background: var(--bg-secondary);\n  border-radius: var(--radius-md);\n}\n\n.toggle-info {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n}\n\n.toggle-label {\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-medium);\n  color: var(--text-primary);\n}\n\n.toggle-desc {\n  font-size: var(--font-size-xs);\n  color: var(--text-tertiary);\n}\n\n.toggle-switch {\n  position: relative;\n  width: 44px;\n  height: 24px;\n  cursor: pointer;\n}\n\n.toggle-switch input {\n  opacity: 0;\n  width: 0;\n  height: 0;\n}\n\n.toggle-slider {\n  position: absolute;\n  inset: 0;\n  background: var(--border-default);\n  border-radius: var(--radius-full);\n  transition: all var(--transition-fast);\n}\n\n.toggle-slider::before {\n  content: '';\n  position: absolute;\n  left: 2px;\n  top: 2px;\n  width: 20px;\n  height: 20px;\n  background: white;\n  border-radius: var(--radius-full);\n  transition: all var(--transition-fast);\n  box-shadow: var(--shadow-sm);\n}\n\n.toggle-switch input:checked + .toggle-slider {\n  background: var(--color-primary);\n}\n\n.toggle-switch input:checked + .toggle-slider::before {\n  transform: translateX(20px);\n}\n\n/* Security Options */\n.security-options {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-sm);\n}\n\n.security-btn {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-md);\n  background: var(--bg-secondary);\n  border-radius: var(--radius-md);\n  font-size: var(--font-size-sm);\n  color: var(--text-primary);\n  transition: all var(--transition-fast);\n}\n\n.security-btn:hover {\n  background: var(--bg-hover);\n}\n\n/* Responsive */\n@media (max-width: 640px) {\n  .settings-body {\n    flex-direction: column;\n  }\n\n  .settings-nav {\n    width: 100%;\n    flex-direction: row;\n    overflow-x: auto;\n    border-right: none;\n    border-bottom: 1px solid var(--border-light);\n  }\n\n  .settings-nav-item {\n    white-space: nowrap;\n  }\n}\n"],["STYLE",{},"/* Header.css - Top Navigation Bar Styles */\n\n.header {\n  height: var(--header-height);\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 0 var(--space-lg);\n  background: var(--bg-primary);\n  border-bottom: 1px solid var(--border-light);\n  flex-shrink: 0;\n  z-index: var(--z-sticky);\n}\n\n.header-left {\n  display: flex;\n  align-items: center;\n  gap: var(--space-md);\n}\n\n.header-btn {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 36px;\n  height: 36px;\n  border-radius: var(--radius-md);\n  color: var(--text-secondary);\n  transition: all var(--transition-fast);\n}\n\n.header-btn:hover {\n  background: var(--bg-hover);\n  color: var(--text-primary);\n}\n\n.sidebar-toggle {\n  display: flex;\n}\n\n.header-brand {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n}\n\n.brand-title {\n  font-size: var(--font-size-lg);\n  font-weight: var(--font-weight-semibold);\n  background: var(--gradient-primary);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n\n/* Model Selector */\n.header-center {\n  position: absolute;\n  left: 50%;\n  transform: translateX(-50%);\n}\n\n.model-selector {\n  position: relative;\n}\n\n.model-selector-btn {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-sm) var(--space-md);\n  background: var(--bg-secondary);\n  border: 1px solid var(--border-light);\n  border-radius: var(--radius-full);\n  font-size: var(--font-size-sm);\n  transition: all var(--transition-fast);\n}\n\n.model-selector-btn:hover {\n  background: var(--bg-tertiary);\n  border-color: var(--border-default);\n}\n\n.model-name {\n  font-weight: var(--font-weight-medium);\n  color: var(--text-primary);\n}\n\n.model-menu-backdrop,\n.user-menu-backdrop {\n  position: fixed;\n  inset: 0;\n  z-index: calc(var(--z-dropdown) - 1);\n}\n\n.model-menu {\n  position: absolute;\n  top: calc(100% + var(--space-sm));\n  left: 50%;\n  transform: translateX(-50%);\n  min-width: 220px;\n  background: var(--bg-primary);\n  border: 1px solid var(--border-light);\n  border-radius: var(--radius-lg);\n  box-shadow: var(--shadow-lg);\n  z-index: var(--z-dropdown);\n  overflow: hidden;\n  animation: slideDown var(--transition-fast) ease-out;\n}\n\n.model-menu-item {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  width: 100%;\n  padding: var(--space-md);\n  text-align: left;\n  transition: background var(--transition-fast);\n}\n\n.model-menu-item:hover {\n  background: var(--bg-hover);\n}\n\n.model-menu-item.active {\n  background: var(--color-primary-light);\n}\n\n.model-info {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n}\n\n.model-item-name {\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-medium);\n  color: var(--text-primary);\n}\n\n.model-item-desc {\n  font-size: var(--font-size-xs);\n  color: var(--text-tertiary);\n}\n\n.model-check {\n  color: var(--color-primary);\n  font-weight: var(--font-weight-bold);\n}\n\n/* Header Right */\n.header-right {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n}\n\n.lang-toggle {\n  padding: var(--space-xs) var(--space-sm);\n  border: 1px solid var(--border-default);\n  border-radius: var(--radius-full);\n  font-size: var(--font-size-xs);\n  font-weight: var(--font-weight-semibold);\n  color: var(--text-secondary);\n  transition: all var(--transition-fast);\n}\n\n.lang-toggle:hover {\n  background: var(--bg-hover);\n  color: var(--text-primary);\n}\n\n/* User Menu */\n.user-menu-container {\n  position: relative;\n}\n\n.user-avatar-btn {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-xs) var(--space-sm);\n  border-radius: var(--radius-full);\n  transition: background var(--transition-fast);\n}\n\n.user-avatar-btn:hover {\n  background: var(--bg-hover);\n}\n\n.user-avatar {\n  width: 28px;\n  height: 28px;\n  border-radius: var(--radius-full);\n  background: var(--gradient-primary);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: white;\n}\n\n.user-name {\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-medium);\n  color: var(--text-primary);\n}\n\n.user-menu {\n  position: absolute;\n  top: calc(100% + var(--space-sm));\n  right: 0;\n  min-width: 200px;\n  background: var(--bg-primary);\n  border: 1px solid var(--border-light);\n  border-radius: var(--radius-lg);\n  box-shadow: var(--shadow-lg);\n  z-index: var(--z-dropdown);\n  overflow: hidden;\n  animation: slideDown var(--transition-fast) ease-out;\n}\n\n.user-menu-header {\n  padding: var(--space-md);\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n}\n\n.user-menu-name {\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-semibold);\n  color: var(--text-primary);\n}\n\n.user-menu-role {\n  font-size: var(--font-size-xs);\n  color: var(--text-tertiary);\n}\n\n.user-menu-divider {\n  height: 1px;\n  background: var(--border-light);\n}\n\n.user-menu-item {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  width: 100%;\n  padding: var(--space-sm) var(--space-md);\n  font-size: var(--font-size-sm);\n  color: var(--text-secondary);\n  transition: all var(--transition-fast);\n}\n\n.user-menu-item:hover {\n  background: var(--bg-hover);\n  color: var(--text-primary);\n}\n\n.user-menu-item.logout:hover {\n  background: rgba(239, 68, 68, 0.1);\n  color: var(--color-error);\n}\n\n/* Responsive */\n@media (max-width: 768px) {\n  .header {\n    padding: 0 var(--space-md);\n  }\n\n  .header-center {\n    display: none;\n  }\n\n  .user-name {\n    display: none;\n  }\n}\n"],["STYLE",{},"/* Sidebar.css - Redesigned Chat Sidebar */\n\n.sidebar {\n  width: var(--sidebar-width);\n  height: 100%;\n  background: var(--bg-secondary);\n  border-right: 1px solid var(--border-light);\n  display: flex;\n  flex-direction: column;\n  flex-shrink: 0;\n  transition: width var(--transition-slow), transform var(--transition-slow);\n  overflow: hidden;\n}\n\n.sidebar.collapsed {\n  width: 0;\n  transform: translateX(-100%);\n}\n\n/* Header */\n.sidebar-header {\n  padding: var(--space-lg);\n  flex-shrink: 0;\n}\n\n.new-chat-btn {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: var(--space-sm);\n  width: 100%;\n  padding: var(--space-md) var(--space-lg);\n  background: var(--gradient-primary);\n  color: white;\n  border-radius: var(--radius-lg);\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-medium);\n  transition: all var(--transition-fast);\n  box-shadow: 0 2px 8px rgba(102, 126, 234, 0.3);\n}\n\n.new-chat-btn:hover {\n  transform: translateY(-1px);\n  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);\n}\n\n.new-chat-btn:active {\n  transform: translateY(0);\n}\n\n/* Search */\n.sidebar-search {\n  position: relative;\n  padding: 0 var(--space-lg);\n  margin-bottom: var(--space-md);\n  flex-shrink: 0;\n}\n\n.search-icon {\n  position: absolute;\n  left: calc(var(--space-lg) + var(--space-sm));\n  top: 50%;\n  transform: translateY(-50%);\n  color: var(--text-muted);\n  pointer-events: none;\n}\n\n.search-input {\n  width: 100%;\n  padding: var(--space-sm) var(--space-md);\n  padding-left: calc(var(--space-lg) + var(--space-sm));\n  background: var(--bg-primary);\n  border: 1px solid var(--border-light);\n  border-radius: var(--radius-md);\n  font-size: var(--font-size-sm);\n  transition: all var(--transition-fast);\n}\n\n.search-input:focus {\n  outline: none;\n  border-color: var(--color-primary);\n  box-shadow: 0 0 0 3px var(--color-primary-light);\n}\n\n/* Session List */\n.session-list {\n  flex: 1;\n  overflow-y: auto;\n  padding: 0 var(--space-sm);\n}\n\n.session-loading,\n.session-empty {\n  padding: var(--space-xl);\n  text-align: center;\n  color: var(--text-tertiary);\n}\n\n.empty-icon {\n  margin-bottom: var(--space-md);\n  opacity: 0.5;\n}\n\n.session-empty p {\n  font-size: var(--font-size-sm);\n  margin-bottom: var(--space-xs);\n}\n\n.empty-hint {\n  font-size: var(--font-size-xs);\n  color: var(--text-muted);\n}\n\n/* Session Item */\n.session-item {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-md);\n  margin-bottom: var(--space-xs);\n  background: var(--bg-primary);\n  border-radius: var(--radius-lg);\n  cursor: pointer;\n  transition: all var(--transition-fast);\n  border: 1px solid transparent;\n  position: relative;\n}\n\n.session-item:hover {\n  background: var(--bg-hover);\n  border-color: var(--border-light);\n}\n\n.session-item:hover .session-delete,\n.session-item:hover .session-bookmark,\n.session-item:hover .session-tag-btn {\n  opacity: 1;\n}\n\n.session-item.active {\n  background: var(--color-primary-light);\n  border-color: var(--color-primary);\n}\n\n.session-item.active .session-title {\n  color: var(--color-primary);\n  font-weight: var(--font-weight-medium);\n}\n\n.session-icon {\n  width: 32px;\n  height: 32px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: var(--bg-tertiary);\n  border-radius: var(--radius-md);\n  color: var(--text-tertiary);\n  flex-shrink: 0;\n}\n\n.session-item.active .session-icon {\n  background: var(--color-primary);\n  color: white;\n}\n\n.session-content {\n  flex: 1;\n  min-width: 0;\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n}\n\n.session-title {\n  font-size: var(--font-size-sm);\n  color: var(--text-primary);\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n\n.session-time {\n  font-size: var(--font-size-xs);\n  color: var(--text-muted);\n}\n\n.session-meta {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n}\n\n.session-tags {\n  display: flex;\n  gap: 4px;\n}\n\n.session-tag {\n  padding: 1px 6px;\n  border-radius: var(--radius-sm);\n  font-size: 10px;\n  font-weight: var(--font-weight-medium);\n}\n\n.session-tag-more {\n  font-size: 10px;\n  color: var(--text-tertiary);\n}\n\n.session-actions {\n  display: flex;\n  align-items: center;\n  gap: 2px;\n}\n\n.session-bookmark,\n.session-tag-btn,\n.session-delete {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 28px;\n  height: 28px;\n  border-radius: var(--radius-md);\n  color: var(--text-muted);\n  opacity: 0;\n  transition: all var(--transition-fast);\n  flex-shrink: 0;\n  background: none;\n  border: none;\n  cursor: pointer;\n}\n\n.session-bookmark:hover {\n  background: rgba(245, 158, 11, 0.1);\n  color: var(--color-warning);\n}\n\n.session-bookmark.active {\n  opacity: 1;\n  color: var(--color-warning);\n}\n\n.session-tag-btn:hover {\n  background: rgba(79, 70, 229, 0.1);\n  color: var(--color-primary);\n}\n\n.session-delete:hover {\n  background: rgba(239, 68, 68, 0.1);\n  color: var(--color-error);\n}\n\n.session-delete.confirm {\n  opacity: 1;\n  background: rgba(239, 68, 68, 0.1);\n  color: var(--color-error);\n}\n\n/* Session Groups */\n.session-group {\n  margin-bottom: var(--space-sm);\n}\n\n.session-group-header {\n  display: flex;\n  align-items: center;\n  gap: var(--space-xs);\n  padding: var(--space-xs) var(--space-sm);\n  cursor: pointer;\n  border-radius: var(--radius-md);\n  transition: background var(--transition-fast);\n}\n\n.session-group-header:hover {\n  background: var(--bg-hover);\n}\n\n.group-toggle {\n  display: flex;\n  align-items: center;\n  color: var(--text-tertiary);\n}\n\n.group-title {\n  flex: 1;\n  font-size: var(--font-size-xs);\n  font-weight: var(--font-weight-semibold);\n  color: var(--text-secondary);\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n}\n\n.group-count {\n  font-size: var(--font-size-xs);\n  color: var(--text-tertiary);\n  background: var(--bg-tertiary);\n  padding: 0 6px;\n  border-radius: var(--radius-full);\n}\n\n.session-group-items {\n  margin-top: var(--space-xs);\n}\n\n/* Tag Menu */\n.tag-menu {\n  position: absolute;\n  right: 0;\n  top: 100%;\n  margin-top: var(--space-xs);\n  width: 180px;\n  background: var(--bg-primary);\n  border: 1px solid var(--border-light);\n  border-radius: var(--radius-lg);\n  box-shadow: var(--shadow-lg);\n  z-index: 100;\n  overflow: hidden;\n}\n\n.tag-menu-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: var(--space-sm) var(--space-md);\n  background: var(--bg-secondary);\n  border-bottom: 1px solid var(--border-light);\n  font-size: var(--font-size-xs);\n  color: var(--text-secondary);\n}\n\n.tag-menu-close {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 18px;\n  height: 18px;\n  border: none;\n  background: transparent;\n  color: var(--text-tertiary);\n  cursor: pointer;\n  border-radius: var(--radius-sm);\n}\n\n.tag-menu-close:hover {\n  background: var(--bg-hover);\n  color: var(--text-primary);\n}\n\n.tag-menu-list {\n  padding: var(--space-xs);\n}\n\n.tag-menu-item {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-sm);\n  border-radius: var(--radius-md);\n  cursor: pointer;\n  transition: background var(--transition-fast);\n}\n\n.tag-menu-item:hover {\n  background: var(--bg-hover);\n}\n\n.tag-menu-item.selected {\n  background: rgba(79, 70, 229, 0.1);\n}\n\n.tag-menu-dot {\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  flex-shrink: 0;\n}\n\n.tag-menu-label {\n  flex: 1;\n  font-size: var(--font-size-sm);\n  color: var(--text-primary);\n}\n\n.tag-menu-check {\n  font-size: var(--font-size-xs);\n  color: var(--color-primary);\n}\n\n/* Footer */\n.sidebar-footer {\n  padding: var(--space-md) var(--space-lg);\n  border-top: 1px solid var(--border-light);\n  flex-shrink: 0;\n}\n\n.footer-hint {\n  font-size: var(--font-size-xs);\n  color: var(--text-muted);\n}\n\n/* Responsive */\n@media (max-width: 768px) {\n  .sidebar {\n    position: fixed;\n    left: 0;\n    top: var(--header-height);\n    height: calc(100vh - var(--header-height));\n    z-index: var(--z-sticky);\n    box-shadow: var(--shadow-xl);\n  }\n\n  .sidebar.collapsed {\n    transform: translateX(-100%);\n  }\n}\n"],["STYLE",{},"/* Layout.css - Main Layout Styles */\n\n.layout {\n  display: flex;\n  flex-direction: column;\n  height: 100vh;\n  width: 100vw;\n  overflow: hidden;\n  background: var(--bg-primary);\n}\n\n.layout-body {\n  display: flex;\n  flex: 1;\n  min-height: 0;\n  overflow: hidden;\n}\n\n.layout-main {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  min-width: 0;\n  overflow: hidden;\n  transition: margin-left var(--transition-slow);\n}\n\n.layout-main.sidebar-collapsed {\n  margin-left: 0;\n}\n\n/* Allow scrolling within content */\n.app-content {\n  flex: 1;\n  min-height: 0;\n  overflow: hidden;\n  display: flex;\n  flex-direction: column;\n}\n"],["STYLE",{},"/* ChartTypeSelector - uses global .chart-type-selector styles from MessageItem.css */\n"],["STYLE",{},".code-block {\n  border-radius: var(--radius-md);\n  overflow: hidden;\n  margin: var(--space-md) 0;\n  background: #1e1e1e;\n}\n\n.code-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: var(--space-sm) var(--space-md);\n  background: #2d2d2d;\n  border-bottom: 1px solid #3d3d3d;\n}\n\n.code-lang {\n  font-size: var(--font-size-xs);\n  color: var(--text-tertiary);\n  font-family: var(--font-mono);\n  text-transform: uppercase;\n}\n\n.code-copy-btn {\n  display: flex;\n  align-items: center;\n  gap: var(--space-xs);\n  padding: var(--space-xs) var(--space-sm);\n  background: transparent;\n  border: none;\n  border-radius: var(--radius-sm);\n  color: var(--text-tertiary);\n  font-size: var(--font-size-xs);\n  cursor: pointer;\n  transition: all var(--transition-fast);\n}\n\n.code-copy-btn:hover {\n  background: rgba(255, 255, 255, 0.1);\n  color: var(--text-primary);\n}\n\n.code-copy-btn.copied {\n  color: var(--color-success);\n}\n"],["STYLE",{},"/* MessageItem.css - Single Message Styles */\n\n.message-item {\n  display: flex;\n  gap: var(--space-md);\n  padding: var(--space-md) 0;\n  animation: messageSlideIn 0.3s ease-out;\n}\n\n@keyframes messageSlideIn {\n  from { opacity: 0; transform: translateY(10px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n\n/* Avatar */\n.message-avatar {\n  width: 36px;\n  height: 36px;\n  border-radius: var(--radius-full);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n}\n\n.user .message-avatar {\n  background: var(--gradient-primary);\n  color: white;\n}\n\n.assistant .message-avatar {\n  background: var(--gradient-accent);\n  color: white;\n}\n\n/* Body */\n.message-body {\n  flex: 1;\n  min-width: 0;\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-sm);\n}\n\n/* Bubble */\n.message-bubble {\n  padding: var(--space-md) var(--space-lg);\n  border-radius: var(--radius-xl);\n  max-width: 100%;\n  position: relative;\n}\n\n.user .message-bubble {\n  background: var(--gradient-primary);\n  color: white;\n  border-bottom-right-radius: var(--radius-sm);\n  margin-left: auto;\n  max-width: fit-content;\n}\n\n.assistant .message-bubble {\n  background: var(--bg-secondary);\n  border: 1px solid var(--border-light);\n  border-bottom-left-radius: var(--radius-sm);\n}\n\n.message-item.error .message-bubble {\n  background: rgba(239, 68, 68, 0.1);\n  border-color: rgba(239, 68, 68, 0.3);\n}\n\n/* Message Content */\n.message-content {\n  font-size: var(--font-size-sm);\n  line-height: var(--line-height-relaxed);\n  color: var(--text-primary);\n  word-break: break-word;\n}\n\n.message-text {\n  font-size: var(--font-size-sm);\n  line-height: var(--line-height-relaxed);\n  color: var(--text-primary);\n  word-break: break-word;\n}\n\n.user .message-text { color: white; }\n\n/* Streaming Cursor */\n.streaming-cursor {\n  display: inline-block;\n  width: 8px;\n  height: 16px;\n  background: var(--color-primary);\n  margin-left: 2px;\n  vertical-align: text-bottom;\n  animation: cursorBlink 0.8s infinite;\n}\n\n@keyframes cursorBlink {\n  0%, 50% { opacity: 1; }\n  51%, 100% { opacity: 0; }\n}\n\n/* ========== Message Header (Metadata) ========== */\n.message-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: var(--space-md);\n  padding: var(--space-sm) var(--space-md);\n  margin-bottom: var(--space-sm);\n  background: linear-gradient(135deg, rgba(79, 70, 229, 0.08) 0%, rgba(59, 130, 246, 0.08) 100%);\n  border-radius: var(--radius-md);\n  border: 1px solid var(--border-light);\n}\n\n.header-meta {\n  display: flex;\n  align-items: center;\n  gap: var(--space-md);\n  font-size: var(--font-size-xs);\n  color: var(--text-tertiary);\n}\n\n.header-meta > div {\n  display: flex;\n  align-items: center;\n  gap: var(--space-xs);\n}\n\n.header-badge {\n  display: flex;\n  align-items: center;\n  gap: var(--space-xs);\n  padding: 2px 8px;\n  background: rgba(16, 185, 129, 0.1);\n  color: var(--color-success);\n  border-radius: var(--radius-full);\n  font-size: var(--font-size-xs);\n  font-weight: var(--font-weight-medium);\n}\n\n.header-badge.warning {\n  background: rgba(245, 158, 11, 0.1);\n  color: var(--color-warning);\n}\n\n.header-badge.error {\n  background: rgba(239, 68, 68, 0.1);\n  color: var(--color-error);\n}\n\n/* Footer */\n.message-footer {\n  display: flex;\n  align-items: center;\n  gap: var(--space-md);\n  padding: 0 var(--space-sm);\n  opacity: 0;\n  transition: opacity var(--transition-fast);\n}\n\n.message-footer.visible { opacity: 1; }\n\n.message-time {\n  display: flex;\n  align-items: center;\n  gap: var(--space-xs);\n  font-size: var(--font-size-xs);\n  color: var(--text-muted);\n}\n\n/* Actions */\n.message-actions {\n  display: flex;\n  align-items: center;\n  gap: var(--space-xs);\n}\n\n.action-divider {\n  width: 1px;\n  height: 16px;\n  background: var(--border-light);\n  margin: 0 var(--space-xs);\n}\n\n.action-btn {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 28px;\n  height: 28px;\n  border-radius: var(--radius-md);\n  color: var(--text-tertiary);\n  background: transparent;\n  border: none;\n  cursor: pointer;\n  transition: all var(--transition-fast);\n}\n\n.action-btn:hover {\n  background: var(--bg-hover);\n  color: var(--text-primary);\n}\n\n.action-btn.liked { color: var(--color-success); background: rgba(16, 185, 129, 0.1); }\n.action-btn.disliked { color: var(--color-error); background: rgba(239, 68, 68, 0.1); }\n\n/* ========== Thinking Chain ========== */\n.thinking-chain {\n  margin-bottom: var(--space-lg);\n  background: var(--bg-tertiary);\n  border-radius: var(--radius-lg);\n  border: 1px solid var(--border-light);\n  overflow: hidden;\n}\n\n.thinking-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: var(--space-md);\n  background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(59, 130, 246, 0.1) 100%);\n  cursor: pointer;\n  transition: background var(--transition-fast);\n}\n\n.thinking-header:hover { background: var(--bg-hover); }\n\n.thinking-title {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-semibold);\n  color: var(--color-primary);\n}\n\n.thinking-actions {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  color: var(--text-tertiary);\n  font-size: var(--font-size-xs);\n}\n\n.thinking-toggle {\n  display: flex;\n  align-items: center;\n  gap: var(--space-xs);\n  padding: var(--space-xs) var(--space-sm);\n  background: transparent;\n  border: 1px solid var(--border-light);\n  border-radius: var(--radius-sm);\n  color: var(--text-secondary);\n  font-size: var(--font-size-xs);\n  cursor: pointer;\n  transition: all var(--transition-fast);\n}\n\n.thinking-toggle:hover {\n  background: var(--bg-primary);\n  border-color: var(--color-primary);\n}\n\n.thinking-content {\n  padding: var(--space-lg);\n  animation: fadeIn 0.3s ease-out;\n}\n\n@keyframes fadeIn {\n  from { opacity: 0; }\n  to { opacity: 1; }\n}\n\n.thinking-steps {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-md);\n}\n\n.thinking-step {\n  display: flex;\n  gap: var(--space-md);\n}\n\n.step-indicator {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  width: 20px;\n}\n\n.step-dot {\n  width: 10px;\n  height: 10px;\n  border-radius: 50%;\n  background: var(--color-primary);\n  flex-shrink: 0;\n}\n\n.step-line {\n  width: 2px;\n  flex: 1;\n  background: var(--border-light);\n  margin-top: var(--space-xs);\n}\n\n.step-content {\n  display: flex;\n  align-items: flex-start;\n  gap: var(--space-sm);\n  flex: 1;\n  padding: var(--space-sm) var(--space-md);\n  background: var(--bg-primary);\n  border-radius: var(--radius-md);\n  font-size: var(--font-size-sm);\n  color: var(--text-secondary);\n}\n\n.step-number {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 20px;\n  height: 20px;\n  border-radius: 50%;\n  background: var(--color-primary);\n  color: white;\n  font-size: var(--font-size-xs);\n  font-weight: var(--font-weight-bold);\n  flex-shrink: 0;\n}\n\n.step-icon {\n  display: flex;\n  color: var(--color-primary);\n  flex-shrink: 0;\n}\n\n.step-text { flex: 1; }\n\n/* Thinking Chain - Enhanced Types */\n.thinking-step.action .step-dot { background: var(--color-primary); }\n.thinking-step.action .step-content { background: rgba(79, 70, 229, 0.08); }\n\n.thinking-step.result .step-dot { background: var(--color-success); }\n.thinking-step.result .step-content { background: rgba(16, 185, 129, 0.08); }\n\n.thinking-step.error .step-dot { background: var(--color-error); }\n.thinking-step.error .step-content { background: rgba(239, 68, 68, 0.08); }\n\n.thinking-step.source .step-content {\n  background: rgba(59, 130, 246, 0.08);\n  border-left: 2px solid var(--color-info);\n}\n\n.step-source {\n  display: inline-flex;\n  align-items: center;\n  gap: 4px;\n  padding: 1px 6px;\n  background: rgba(59, 130, 246, 0.15);\n  color: var(--color-info);\n  border-radius: var(--radius-sm);\n  font-size: var(--font-size-xs);\n  margin-left: var(--space-xs);\n}\n\n/* ========== Structured Blocks ========== */\n.block-text,\n.block-table,\n.block-chart,\n.block-metrics,\n.block-steps,\n.block-sql {\n  margin-bottom: var(--space-md);\n}\n\n.block-text:last-child,\n.block-code:last-child {\n  margin-bottom: 0;\n}\n\n/* Table */\n.structured-table {\n  background: var(--bg-primary);\n  border-radius: var(--radius-lg);\n  border: 1px solid var(--border-light);\n  overflow: hidden;\n}\n\n.table-header {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-md);\n  background: var(--bg-secondary);\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-medium);\n  color: var(--text-primary);\n}\n\n.table-count {\n  margin-left: auto;\n  font-size: var(--font-size-xs);\n  color: var(--text-tertiary);\n  font-weight: normal;\n}\n\n.table-scroll {\n  overflow-x: auto;\n  max-height: 400px;\n  overflow-y: auto;\n}\n\n.data-table {\n  width: 100%;\n  border-collapse: collapse;\n  font-size: var(--font-size-sm);\n}\n\n.data-table th,\n.data-table td {\n  padding: var(--space-sm) var(--space-md);\n  text-align: left;\n  border-bottom: 1px solid var(--border-light);\n  white-space: nowrap;\n}\n\n.data-table th {\n  background: var(--bg-secondary);\n  font-weight: var(--font-weight-semibold);\n  color: var(--text-secondary);\n  position: sticky;\n  top: 0;\n  z-index: 1;\n}\n\n.data-table tr:hover td {\n  background: var(--bg-hover);\n}\n\n/* Toggle (Table/Chart Switcher) */\n.structured-toggle {\n  background: var(--bg-primary);\n  border-radius: var(--radius-lg);\n  border: 1px solid var(--border-light);\n  overflow: hidden;\n}\n\n.toggle-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: var(--space-md);\n  background: var(--bg-secondary);\n  border-bottom: 1px solid var(--border-light);\n}\n\n.toggle-title {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-medium);\n  color: var(--text-primary);\n}\n\n.toggle-subtitle {\n  font-weight: normal;\n  color: var(--text-secondary);\n  font-size: var(--font-size-xs);\n}\n\n.toggle-summary {\n  display: flex;\n  gap: var(--space-lg);\n  padding: var(--space-md);\n  background: var(--bg-tertiary);\n  border-bottom: 1px solid var(--border-light);\n}\n\n.summary-item {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n}\n\n.summary-label {\n  font-size: var(--font-size-xs);\n  color: var(--text-secondary);\n}\n\n.summary-value {\n  font-size: var(--font-size-lg);\n  font-weight: var(--font-weight-bold);\n  color: var(--primary);\n}\n\n.toggle-buttons {\n  display: flex;\n  gap: var(--space-xs);\n  background: var(--bg-tertiary);\n  padding: 2px;\n  border-radius: var(--radius-md);\n}\n\n.toggle-btn {\n  display: flex;\n  align-items: center;\n  gap: 4px;\n  padding: 4px 12px;\n  border: none;\n  background: transparent;\n  color: var(--text-secondary);\n  font-size: var(--font-size-xs);\n  border-radius: var(--radius-sm);\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.toggle-btn:hover {\n  color: var(--text-primary);\n}\n\n.toggle-btn.active {\n  background: var(--bg-primary);\n  color: var(--primary);\n  box-shadow: var(--shadow-sm);\n}\n\n.toggle-content {\n  padding: var(--space-md);\n  overflow-x: auto;\n}\n\n.toggle-content .structured-table {\n  min-width: max-content;\n}\n\n/* Chart */\n.structured-chart {\n  background: var(--bg-primary);\n  border-radius: var(--radius-lg);\n  border: 1px solid var(--border-light);\n  padding: var(--space-md);\n}\n\n.chart-header {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  margin-bottom: var(--space-md);\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-medium);\n  color: var(--text-primary);\n}\n\n.chart-legend {\n  display: flex;\n  gap: var(--space-md);\n  margin-left: auto;\n  flex-wrap: wrap;\n}\n\n.legend-item {\n  display: flex;\n  align-items: center;\n  gap: var(--space-xs);\n  font-size: var(--font-size-xs);\n  color: var(--text-secondary);\n}\n\n.legend-dot {\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n}\n\n/* Metrics */\n.structured-metrics {\n  background: var(--bg-primary);\n  border-radius: var(--radius-lg);\n  border: 1px solid var(--border-light);\n  padding: var(--space-md);\n}\n\n.metrics-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));\n  gap: var(--space-md);\n}\n\n.metric-card {\n  padding: var(--space-md);\n  background: var(--bg-tertiary);\n  border-radius: var(--radius-md);\n}\n\n.metric-label {\n  font-size: var(--font-size-xs);\n  color: var(--text-secondary);\n  margin-bottom: var(--space-xs);\n}\n\n.metric-value {\n  font-size: var(--font-size-xl);\n  font-weight: var(--font-weight-bold);\n  color: var(--text-primary);\n  margin-bottom: var(--space-sm);\n}\n\n.metric-bar {\n  height: 4px;\n  background: var(--bg-secondary);\n  border-radius: var(--radius-full);\n  overflow: hidden;\n}\n\n.metric-bar-fill {\n  height: 100%;\n  background: var(--color-primary);\n  border-radius: var(--radius-full);\n  transition: width 0.5s ease-out;\n}\n\n/* Steps */\n.structured-steps {\n  background: var(--bg-primary);\n  border-radius: var(--radius-lg);\n  border: 1px solid var(--border-light);\n  overflow: hidden;\n}\n\n.steps-header {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-md);\n  background: var(--bg-secondary);\n  cursor: pointer;\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-medium);\n  color: var(--text-primary);\n  transition: background var(--transition-fast);\n}\n\n.steps-header:hover { background: var(--bg-hover); }\n\n.steps-count {\n  font-size: var(--font-size-xs);\n  color: var(--text-tertiary);\n  font-weight: normal;\n}\n\n.steps-count::before { content: '('; }\n.steps-count::after { content: ')'; }\n\n.steps-header span:first-of-type { flex: 1; }\n\n.steps-content {\n  padding: var(--space-lg);\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-md);\n}\n\n.step-item {\n  display: flex;\n  gap: var(--space-md);\n  align-items: flex-start;\n}\n\n.step-item .step-number {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 24px;\n  height: 24px;\n  border-radius: 50%;\n  background: var(--color-primary);\n  color: white;\n  font-size: var(--font-size-xs);\n  font-weight: var(--font-weight-bold);\n  flex-shrink: 0;\n}\n\n.step-item .step-text {\n  flex: 1;\n  padding: var(--space-sm) var(--space-md);\n  background: var(--bg-tertiary);\n  border-radius: var(--radius-md);\n  font-size: var(--font-size-sm);\n  color: var(--text-secondary);\n  line-height: var(--line-height-relaxed);\n}\n\n/* SQL */\n.structured-sql {\n  background: #1e1e1e;\n  border-radius: var(--radius-lg);\n  overflow: hidden;\n}\n\n.sql-header {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-sm) var(--space-md);\n  background: #2d2d2d;\n  font-size: var(--font-size-xs);\n  color: #888;\n  font-family: var(--font-mono);\n}\n\n.sql-content {\n  margin: 0;\n  padding: var(--space-md);\n  font-family: var(--font-mono);\n  font-size: var(--font-size-xs);\n  color: #d4d4d4;\n  overflow-x: auto;\n  white-space: pre;\n}\n\n/* Inline Code */\n.inline-code {\n  padding: 2px 6px;\n  background: var(--bg-tertiary);\n  border-radius: var(--radius-sm);\n  font-family: var(--font-mono);\n  font-size: 0.9em;\n  color: var(--color-primary);\n}\n\n.user .inline-code {\n  background: rgba(255, 255, 255, 0.2);\n  color: white;\n}\n\n/* Markdown */\n.message-content p { margin: 0.5em 0; }\n.message-content ul, .message-content ol { margin: 0.5em 0; padding-left: 1.5em; }\n.message-content li { margin: 0.25em 0; }\n.message-content blockquote {\n  margin: 0.75em 0;\n  padding: 0.5em 1em;\n  border-left: 3px solid var(--color-primary);\n  background: var(--bg-tertiary);\n  border-radius: 0 var(--radius-md) var(--radius-md) 0;\n}\n.message-content h1, .message-content h2, .message-content h3 { margin: 1em 0 0.5em; font-weight: var(--font-weight-semibold); }\n.message-content h1 { font-size: 1.4em; }\n.message-content h2 { font-size: 1.2em; }\n.message-content h3 { font-size: 1.1em; }\n.message-content table { width: 100%; border-collapse: collapse; margin: 0.75em 0; font-size: var(--font-size-sm); }\n.message-content th, .message-content td { padding: var(--space-sm) var(--space-md); border: 1px solid var(--border-light); text-align: left; }\n.message-content th { background: var(--bg-tertiary); font-weight: var(--font-weight-semibold); }\n\n.table-wrapper { overflow-x: auto; margin: 0.75em 0; border-radius: var(--radius-md); border: 1px solid var(--border-light); }\n.link { color: var(--color-primary); text-decoration: none; border-bottom: 1px solid transparent; transition: border-color var(--transition-fast); }\n.link:hover { border-bottom-color: var(--color-primary); }\n\n/* ========== Citation ========== */\n.citation-marker {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  width: 16px;\n  height: 16px;\n  background: var(--color-primary);\n  color: white;\n  border-radius: var(--radius-sm);\n  font-size: 10px;\n  font-weight: var(--font-weight-bold);\n  cursor: pointer;\n  margin-right: 4px;\n  vertical-align: super;\n  transition: all var(--transition-fast);\n}\n\n.citation-marker:hover {\n  background: var(--color-primary-dark);\n  transform: scale(1.1);\n}\n\n.citation-list {\n  display: flex;\n  flex-wrap: wrap;\n  gap: var(--space-sm);\n  margin-top: var(--space-md);\n  padding-top: var(--space-md);\n  border-top: 1px solid var(--border-light);\n}\n\n.citation-item {\n  display: flex;\n  align-items: center;\n  gap: var(--space-xs);\n  padding: var(--space-xs) var(--space-sm);\n  background: var(--bg-tertiary);\n  border-radius: var(--radius-sm);\n  font-size: var(--font-size-xs);\n  color: var(--text-secondary);\n  cursor: pointer;\n  transition: all var(--transition-fast);\n}\n\n.citation-item:hover {\n  background: var(--bg-hover);\n  color: var(--text-primary);\n}\n\n.citation-item .citation-num {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 14px;\n  height: 14px;\n  background: var(--color-primary);\n  color: white;\n  border-radius: 3px;\n  font-size: 9px;\n  font-weight: var(--font-weight-bold);\n}\n\n/* ========== Table Sort & Filter ========== */\n.table-controls {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-sm) var(--space-md);\n  background: var(--bg-tertiary);\n  border-bottom: 1px solid var(--border-light);\n}\n\n.table-filter-input {\n  flex: 1;\n  padding: var(--space-xs) var(--space-sm);\n  border: 1px solid var(--border-light);\n  border-radius: var(--radius-sm);\n  font-size: var(--font-size-xs);\n  background: var(--bg-primary);\n  color: var(--text-primary);\n  outline: none;\n  transition: border-color var(--transition-fast);\n}\n\n.table-filter-input:focus {\n  border-color: var(--color-primary);\n}\n\n.table-filter-input::placeholder {\n  color: var(--text-tertiary);\n}\n\n.table-search-wrapper {\n  position: relative;\n  display: flex;\n  align-items: center;\n  flex: 1;\n}\n\n.table-filter-icon {\n  position: absolute;\n  left: 8px;\n  color: var(--text-tertiary);\n  pointer-events: none;\n}\n\n.table-search-wrapper .table-filter-input {\n  padding-left: 28px;\n}\n\n.table-filter-clear {\n  position: absolute;\n  right: 8px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 16px;\n  height: 16px;\n  border: none;\n  background: var(--bg-tertiary);\n  color: var(--text-tertiary);\n  border-radius: 50%;\n  cursor: pointer;\n  transition: all var(--transition-fast);\n}\n\n.table-filter-clear:hover {\n  background: var(--bg-hover);\n  color: var(--text-primary);\n}\n\n.table-export-btn {\n  display: flex;\n  align-items: center;\n  gap: 4px;\n  padding: var(--space-xs) var(--space-sm);\n  background: var(--bg-primary);\n  border: 1px solid var(--border-light);\n  border-radius: var(--radius-sm);\n  font-size: var(--font-size-xs);\n  color: var(--text-secondary);\n  cursor: pointer;\n  transition: all var(--transition-fast);\n}\n\n.table-export-btn:hover {\n  background: var(--bg-hover);\n  color: var(--text-primary);\n  border-color: var(--color-primary);\n}\n\n.data-table th {\n  cursor: pointer;\n  user-select: none;\n  transition: background var(--transition-fast);\n}\n\n.data-table th:hover {\n  background: var(--bg-hover);\n}\n\n.th-sort-indicator {\n  display: inline-flex;\n  align-items: center;\n  gap: 4px;\n  margin-left: 4px;\n  color: var(--text-tertiary);\n}\n\n.th-sort-indicator.active {\n  color: var(--color-primary);\n}\n\n.th-sort-icon {\n  opacity: 0.3;\n}\n\n.th-sort-indicator.active .th-sort-icon {\n  opacity: 1;\n}\n\n/* ========== Chart Type Selector ========== */\n.chart-type-selector {\n  display: flex;\n  gap: 2px;\n  background: var(--bg-tertiary);\n  padding: 2px;\n  border-radius: var(--radius-md);\n}\n\n.chart-type-btn {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 28px;\n  height: 28px;\n  border: none;\n  background: transparent;\n  color: var(--text-tertiary);\n  border-radius: var(--radius-sm);\n  cursor: pointer;\n  transition: all var(--transition-fast);\n}\n\n.chart-type-btn:hover {\n  color: var(--text-primary);\n  background: var(--bg-hover);\n}\n\n.chart-type-btn.active {\n  background: var(--bg-primary);\n  color: var(--color-primary);\n  box-shadow: var(--shadow-sm);\n}\n\n/* Responsive */\n@media (max-width: 640px) {\n  .message-avatar { width: 32px; height: 32px; }\n  .message-bubble { padding: var(--space-sm) var(--space-md); }\n  .message-footer { opacity: 1; }\n  .metrics-grid { grid-template-columns: repeat(2, 1fr); }\n}\n"],["STYLE",{},"/* MessageList.css - Message List Container Styles */\n\n.message-list {\n  flex: 1;\n  overflow-y: auto;\n  padding: var(--space-lg);\n  scroll-behavior: smooth;\n}\n\n.message-list-inner {\n  max-width: 850px;\n  margin: 0 auto;\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-lg);\n}\n\n/* Empty State */\n.message-list-empty {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  text-align: center;\n  padding: var(--space-3xl);\n  color: var(--text-muted);\n}\n\n.empty-illustration {\n  margin-bottom: var(--space-xl);\n  opacity: 0.8;\n}\n\n.message-list-empty h3 {\n  margin: 0 0 var(--space-sm) 0;\n  font-size: var(--font-size-lg);\n  font-weight: var(--font-weight-semibold);\n  color: var(--text-primary);\n}\n\n.message-list-empty p {\n  margin: 0;\n  font-size: var(--font-size-sm);\n  max-width: 300px;\n  line-height: var(--line-height-relaxed);\n}\n\n/* Typing Indicator */\n.typing-indicator {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-md) var(--space-lg);\n}\n\n.typing-dot {\n  width: 8px;\n  height: 8px;\n  background: var(--color-primary);\n  border-radius: var(--radius-full);\n  animation: typingBounce 1.4s infinite ease-in-out;\n}\n\n.typing-dot:nth-child(1) { animation-delay: -0.32s; }\n.typing-dot:nth-child(2) { animation-delay: -0.16s; }\n.typing-dot:nth-child(3) { animation-delay: 0s; }\n\n@keyframes typingBounce {\n  0%, 80%, 100% {\n    transform: scale(0.6);\n    opacity: 0.4;\n  }\n  40% {\n    transform: scale(1);\n    opacity: 1;\n  }\n}\n\n/* Thinking Indicator */\n.thinking-indicator {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-sm) 0;\n  color: var(--text-tertiary);\n  font-size: var(--font-size-sm);\n}\n\n.thinking-dots {\n  display: flex;\n  gap: 4px;\n}\n\n.thinking-dots span {\n  width: 6px;\n  height: 6px;\n  border-radius: 50%;\n  background: var(--color-primary);\n  animation: thinkingBounce 1.4s infinite ease-in-out;\n}\n\n.thinking-dots span:nth-child(1) { animation-delay: -0.32s; }\n.thinking-dots span:nth-child(2) { animation-delay: -0.16s; }\n.thinking-dots span:nth-child(3) { animation-delay: 0s; }\n\n@keyframes thinkingBounce {\n  0%, 80%, 100% {\n    transform: scale(0.6);\n    opacity: 0.4;\n  }\n  40% {\n    transform: scale(1);\n    opacity: 1;\n  }\n}\n\n/* Validation Status */\n.validation-status {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: var(--space-sm);\n  padding: var(--space-sm) var(--space-md);\n  border-radius: var(--radius-full);\n  font-size: var(--font-size-xs);\n  margin: 0 auto;\n  transition: all var(--transition-fast);\n}\n\n.validation-status.valid {\n  background: rgba(16, 185, 129, 0.1);\n  color: var(--color-success);\n}\n\n.validation-status.invalid {\n  background: rgba(239, 68, 68, 0.1);\n  color: var(--color-error);\n}\n\n.validation-icon {\n  font-weight: var(--font-weight-bold);\n}\n\n.validation-message {\n  opacity: 0.9;\n}\n\n/* Message Skeleton Loading */\n.message-skeleton {\n  display: flex;\n  gap: var(--space-md);\n  padding: var(--space-md) 0;\n}\n\n.message-skeleton .skeleton-avatar {\n  width: 36px;\n  height: 36px;\n  border-radius: var(--radius-full);\n  background: var(--bg-tertiary);\n}\n\n.message-skeleton .skeleton-content {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-sm);\n}\n\n.message-skeleton .skeleton-line {\n  height: 14px;\n  background: var(--bg-tertiary);\n  border-radius: var(--radius-sm);\n  animation: shimmer 1.5s infinite;\n  background: linear-gradient(\n    90deg,\n    var(--bg-tertiary) 0%,\n    var(--bg-secondary) 50%,\n    var(--bg-tertiary) 100%\n  );\n  background-size: 200% 100%;\n}\n\n.message-skeleton .skeleton-line:first-child {\n  width: 60%;\n}\n\n.message-skeleton .skeleton-line:nth-child(2) {\n  width: 80%;\n}\n\n.message-skeleton .skeleton-line:last-child {\n  width: 40%;\n}\n\n@keyframes shimmer {\n  0% { background-position: -200% 0; }\n  100% { background-position: 200% 0; }\n}\n\n/* Scrollbar */\n.message-list::-webkit-scrollbar {\n  width: 6px;\n}\n\n.message-list::-webkit-scrollbar-track {\n  background: transparent;\n}\n\n.message-list::-webkit-scrollbar-thumb {\n  background: var(--scrollbar-thumb);\n  border-radius: var(--radius-full);\n}\n\n.message-list::-webkit-scrollbar-thumb:hover {\n  background: var(--scrollbar-thumb-hover);\n}\n\n/* Quick Scroll to Bottom Button */\n.scroll-to-bottom {\n  position: absolute;\n  bottom: 100px;\n  right: 50%;\n  transform: translateX(50%);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 40px;\n  height: 40px;\n  border-radius: var(--radius-full);\n  background: var(--bg-primary);\n  border: 1px solid var(--border-light);\n  box-shadow: var(--shadow-lg);\n  cursor: pointer;\n  opacity: 0;\n  visibility: hidden;\n  transition: all var(--transition-fast);\n}\n\n.scroll-to-bottom.visible {\n  opacity: 1;\n  visibility: visible;\n}\n\n.scroll-to-bottom:hover {\n  background: var(--bg-hover);\n  transform: translateX(50%) scale(1.05);\n}\n"],["STYLE",{},".mention-picker {\n  position: absolute;\n  bottom: calc(100% + 8px);\n  left: 0;\n  width: 320px;\n  max-height: 300px;\n  background: var(--bg-primary);\n  border: 1px solid var(--border-light);\n  border-radius: var(--radius-lg);\n  box-shadow: var(--shadow-lg);\n  overflow: hidden;\n  z-index: 100;\n  animation: slideUp 0.2s ease-out;\n}\n\n@keyframes slideUp {\n  from {\n    opacity: 0;\n    transform: translateY(8px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n.mention-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: var(--space-sm) var(--space-md);\n  background: var(--bg-secondary);\n  border-bottom: 1px solid var(--border-light);\n  font-size: var(--font-size-xs);\n  color: var(--text-secondary);\n}\n\n.mention-hint {\n  color: var(--text-tertiary);\n}\n\n.mention-list {\n  max-height: 240px;\n  overflow-y: auto;\n}\n\n.mention-empty {\n  padding: var(--space-lg);\n  text-align: center;\n  color: var(--text-tertiary);\n  font-size: var(--font-size-sm);\n}\n\n.mention-item {\n  display: flex;\n  align-items: flex-start;\n  gap: var(--space-sm);\n  padding: var(--space-sm) var(--space-md);\n  cursor: pointer;\n  transition: background var(--transition-fast);\n}\n\n.mention-item:hover,\n.mention-item.selected {\n  background: var(--bg-hover);\n}\n\n.mention-item.selected {\n  background: rgba(79, 70, 229, 0.1);\n}\n\n.mention-icon {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 24px;\n  height: 24px;\n  border-radius: var(--radius-sm);\n  background: var(--bg-tertiary);\n  color: var(--text-tertiary);\n  flex-shrink: 0;\n}\n\n.mention-item.selected .mention-icon {\n  background: rgba(79, 70, 229, 0.15);\n  color: var(--color-primary);\n}\n\n.mention-content {\n  flex: 1;\n  min-width: 0;\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n}\n\n.mention-role {\n  font-size: var(--font-size-xs);\n  font-weight: var(--font-weight-medium);\n  color: var(--text-secondary);\n}\n\n.mention-preview {\n  font-size: var(--font-size-xs);\n  color: var(--text-tertiary);\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n"],["STYLE",{},"/* ChatInput.css - Enhanced Chat Input Styles */\n\n.chat-input-wrapper {\n  max-width: 800px;\n  margin: 0 auto;\n}\n\n.chat-input-main {\n  display: flex;\n  align-items: flex-end;\n  gap: var(--space-md);\n  padding: var(--space-md);\n  background: var(--bg-secondary);\n  border: 1px solid var(--border-light);\n  border-radius: var(--radius-xl);\n  transition: all var(--transition-fast);\n}\n\n.chat-input-main:focus-within {\n  border-color: var(--color-primary);\n  box-shadow: 0 0 0 3px var(--color-primary-light);\n}\n\n.chat-input-main.disabled {\n  opacity: 0.7;\n  pointer-events: none;\n}\n\n.chat-input-field {\n  flex: 1;\n  border: none;\n  background: transparent;\n  font-size: var(--font-size-sm);\n  line-height: var(--line-height-normal);\n  resize: none;\n  outline: none;\n  color: var(--text-primary);\n  max-height: 200px;\n  min-height: 24px;\n  padding: 0;\n  font-family: inherit;\n}\n\n.chat-input-field::placeholder {\n  color: var(--text-muted);\n}\n\n.chat-input-actions {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  flex-shrink: 0;\n}\n\n.char-count {\n  font-size: var(--font-size-xs);\n  color: var(--text-muted);\n  font-family: var(--font-mono);\n}\n\n.send-btn {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 36px;\n  height: 36px;\n  border-radius: var(--radius-full);\n  background: var(--bg-tertiary);\n  color: var(--text-muted);\n  transition: all var(--transition-fast);\n}\n\n.send-btn.active {\n  background: var(--gradient-primary);\n  color: white;\n  box-shadow: 0 2px 8px rgba(102, 126, 234, 0.3);\n}\n\n.send-btn:hover:not(:disabled) {\n  transform: scale(1.05);\n}\n\n.send-btn:active:not(:disabled) {\n  transform: scale(0.95);\n}\n\n.send-btn:disabled {\n  cursor: not-allowed;\n}\n\n.spin {\n  animation: spin 1s linear infinite;\n}\n\n@keyframes spin {\n  from { transform: rotate(0deg); }\n  to { transform: rotate(360deg); }\n}\n\n/* Footer */\n.chat-input-footer {\n  display: flex;\n  justify-content: center;\n  gap: var(--space-lg);\n  margin-top: var(--space-sm);\n  padding: 0 var(--space-md);\n}\n\n.input-hint {\n  display: flex;\n  align-items: center;\n  gap: var(--space-xs);\n  font-size: var(--font-size-xs);\n  color: var(--text-muted);\n}\n\n.input-hint kbd {\n  padding: 2px 6px;\n  background: var(--bg-tertiary);\n  border: 1px solid var(--border-default);\n  border-radius: var(--radius-sm);\n  font-family: var(--font-mono);\n  font-size: 10px;\n}\n\n/* Command Panel */\n.command-panel {\n  position: absolute;\n  bottom: calc(100% + 8px);\n  left: 0;\n  width: 280px;\n  background: var(--bg-primary);\n  border: 1px solid var(--border-light);\n  border-radius: var(--radius-lg);\n  box-shadow: var(--shadow-lg);\n  overflow: hidden;\n  z-index: 100;\n  animation: slideUp 0.2s ease-out;\n}\n\n.command-header {\n  display: flex;\n  align-items: center;\n  gap: var(--space-xs);\n  padding: var(--space-sm) var(--space-md);\n  background: var(--bg-secondary);\n  border-bottom: 1px solid var(--border-light);\n  font-size: var(--font-size-xs);\n  color: var(--text-secondary);\n}\n\n.command-list {\n  max-height: 200px;\n  overflow-y: auto;\n}\n\n.command-item {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n  padding: var(--space-sm) var(--space-md);\n  cursor: pointer;\n  transition: background var(--transition-fast);\n}\n\n.command-item:hover,\n.command-item.selected {\n  background: var(--bg-hover);\n}\n\n.command-item.selected {\n  background: rgba(79, 70, 229, 0.1);\n}\n\n.command-label {\n  font-size: var(--font-size-sm);\n  color: var(--text-primary);\n  font-weight: var(--font-weight-medium);\n}\n\n.command-hint {\n  font-size: var(--font-size-xs);\n  color: var(--text-tertiary);\n  font-family: var(--font-mono);\n}\n\n/* Responsive */\n@media (max-width: 640px) {\n  .chat-input-main {\n    padding: var(--space-sm) var(--space-md);\n  }\n\n  .chat-input-footer {\n    display: none;\n  }\n\n  .send-btn {\n    width: 32px;\n    height: 32px;\n  }\n\n  .command-panel {\n    width: calc(100vw - 32px);\n  }\n}\n"],["STYLE",{},"/* Welcome.css - Welcome Page Styles */\n\n.welcome {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  height: 100%;\n  padding: var(--space-2xl);\n  max-width: 580px;\n  margin: 0 auto;\n  animation: fadeIn var(--transition-slow) ease-out;\n}\n\n/* Header */\n.welcome-header {\n  text-align: center;\n  margin-bottom: var(--space-2xl);\n}\n\n.welcome-logo {\n  width: 56px;\n  height: 56px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: var(--gradient-primary);\n  border-radius: var(--radius-xl);\n  color: white;\n  margin: 0 auto var(--space-lg);\n  box-shadow: 0 8px 24px rgba(102, 126, 234, 0.3);\n}\n\n.welcome-title {\n  font-size: var(--font-size-xl);\n  font-weight: var(--font-weight-bold);\n  background: var(--gradient-primary);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n  margin-bottom: var(--space-xs);\n}\n\n.welcome-subtitle {\n  font-size: var(--font-size-sm);\n  color: var(--text-tertiary);\n}\n\n/* Features - 1x4 Horizontal */\n.welcome-features {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: var(--space-md);\n  width: 100%;\n  margin-bottom: var(--space-2xl);\n}\n\n.feature-card {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-lg) var(--space-md);\n  background: var(--bg-secondary);\n  border-radius: var(--radius-lg);\n  border: 1px solid var(--border-light);\n  transition: all var(--transition-fast);\n  text-align: center;\n}\n\n.feature-card:hover {\n  border-color: var(--color-primary);\n  transform: translateY(-2px);\n  box-shadow: var(--shadow-md);\n}\n\n.feature-icon {\n  width: 36px;\n  height: 36px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: var(--color-primary-light);\n  border-radius: var(--radius-md);\n  color: var(--color-primary);\n  flex-shrink: 0;\n}\n\n.feature-info h3 {\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-semibold);\n  color: var(--text-primary);\n  margin-bottom: 2px;\n}\n\n.feature-info p {\n  font-size: var(--font-size-xs);\n  color: var(--text-tertiary);\n  line-height: var(--line-height-normal);\n}\n\n/* Examples - Categorized */\n.welcome-examples {\n  width: 100%;\n  margin-bottom: var(--space-xl);\n}\n\n.examples-title {\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-medium);\n  color: var(--text-tertiary);\n  margin-bottom: var(--space-md);\n  text-align: center;\n}\n\n.examples-categories {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: var(--space-md);\n}\n\n.example-category {\n  background: var(--bg-secondary);\n  border: 1px solid var(--border-light);\n  border-radius: var(--radius-lg);\n  padding: var(--space-md);\n}\n\n.category-header {\n  display: flex;\n  align-items: center;\n  gap: var(--space-xs);\n  font-size: var(--font-size-xs);\n  font-weight: var(--font-weight-medium);\n  color: var(--color-primary);\n  margin-bottom: var(--space-sm);\n}\n\n.category-examples {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-xs);\n}\n\n.example-item {\n  display: block;\n  width: 100%;\n  padding: var(--space-sm) var(--space-md);\n  background: var(--bg-primary);\n  border: 1px solid var(--border-light);\n  border-radius: var(--radius-md);\n  font-size: var(--font-size-xs);\n  color: var(--text-secondary);\n  text-align: left;\n  transition: all var(--transition-fast);\n}\n\n.example-item:hover {\n  background: var(--color-primary-light);\n  border-color: var(--color-primary);\n  color: var(--color-primary);\n}\n\n/* Hint */\n.welcome-hint {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  font-size: var(--font-size-xs);\n  color: var(--text-muted);\n}\n\n.hint-key {\n  padding: 2px 6px;\n  background: var(--bg-tertiary);\n  border: 1px solid var(--border-default);\n  border-radius: var(--radius-sm);\n  font-family: var(--font-mono);\n  font-size: 10px;\n}\n\n.hint-sep {\n  color: var(--border-default);\n}\n\n/* Responsive */\n@media (max-width: 640px) {\n  .welcome-features {\n    grid-template-columns: repeat(2, 1fr);\n  }\n\n  .examples-categories {\n    grid-template-columns: 1fr;\n  }\n\n  .welcome-hint {\n    display: none;\n  }\n}\n"],["STYLE",{},"/* ChatView.css - Chat Main View Styles */\n\n.chat-view {\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  background: var(--bg-primary);\n}\n\n.chat-messages-container {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  min-height: 0;\n  overflow: hidden;\n}\n\n.chat-input-container {\n  flex-shrink: 0;\n  padding: var(--space-md) var(--space-lg);\n  padding-bottom: var(--space-xl);\n  background: var(--bg-primary);\n  border-top: 1px solid var(--border-light);\n}\n"],["STYLE",{},".dashboard {\n  padding: var(--space-xl);\n  max-width: 1600px;\n  margin: 0 auto;\n  height: 100%;\n  overflow-y: auto;\n  scroll-behavior: smooth;\n}\n\n/* Header */\n.dashboard-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-start;\n  margin-bottom: var(--space-xl);\n  gap: var(--space-lg);\n  flex-wrap: wrap;\n}\n\n.dashboard-title h2 {\n  margin: 0 0 var(--space-xs) 0;\n  color: var(--text-primary);\n  font-size: var(--font-size-2xl);\n  font-weight: var(--font-weight-bold);\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n}\n\n.header-icon {\n  color: var(--color-primary);\n}\n\n.dashboard-subtitle {\n  margin: 0;\n  color: var(--text-tertiary);\n  font-size: var(--font-size-sm);\n}\n\n.dashboard-actions {\n  display: flex;\n  align-items: center;\n  gap: var(--space-md);\n  flex-wrap: wrap;\n}\n\n/* Buttons */\n.btn {\n  display: inline-flex;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-sm) var(--space-lg);\n  border: none;\n  border-radius: var(--radius-md);\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-medium);\n  cursor: pointer;\n  transition: all var(--transition-fast);\n}\n\n.btn-primary {\n  background: var(--color-primary);\n  color: var(--text-inverse);\n}\n\n.btn-primary:hover {\n  background: var(--color-primary-hover);\n}\n\n.btn-outline {\n  background: transparent;\n  border: 1px solid var(--border-default);\n  color: var(--text-primary);\n}\n\n.btn-outline:hover {\n  background: var(--bg-hover);\n  border-color: var(--border-strong);\n}\n\n.btn-outline.active {\n  background: var(--color-primary);\n  color: white;\n  border-color: var(--color-primary);\n}\n\n.btn-icon {\n  padding: var(--space-sm);\n  background: var(--bg-secondary);\n  border: 1px solid var(--border-light);\n  border-radius: var(--radius-md);\n  color: var(--text-secondary);\n}\n\n.btn-icon:hover {\n  background: var(--bg-hover);\n  color: var(--text-primary);\n}\n\n.btn-icon:active {\n  transform: scale(0.95);\n}\n\n/* Select */\n.operator-select {\n  padding: var(--space-sm) var(--space-lg);\n  border: 1px solid var(--border-default);\n  border-radius: var(--radius-md);\n  font-size: var(--font-size-sm);\n  background: var(--bg-primary);\n  color: var(--text-primary);\n  cursor: pointer;\n  min-width: 180px;\n  transition: all var(--transition-fast);\n}\n\n.operator-select:hover {\n  border-color: var(--border-strong);\n}\n\n.operator-select:focus {\n  outline: none;\n  border-color: var(--color-primary);\n  box-shadow: 0 0 0 3px var(--color-primary-light);\n}\n\n.month-input {\n  padding: var(--space-sm) var(--space-md);\n  border: 1px solid var(--border-default);\n  border-radius: var(--radius-md);\n  font-size: var(--font-size-sm);\n  background: var(--bg-primary);\n  color: var(--text-primary);\n}\n\n/* Error Banner */\n.error-banner {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: var(--space-md) var(--space-lg);\n  background: rgba(239, 68, 68, 0.1);\n  border: 1px solid rgba(239, 68, 68, 0.3);\n  border-radius: var(--radius-md);\n  color: var(--color-error);\n  margin-bottom: var(--space-xl);\n}\n\n.error-banner button {\n  background: none;\n  border: none;\n  color: var(--color-error);\n  font-size: 18px;\n  cursor: pointer;\n  padding: 0 var(--space-sm);\n}\n\n/* Loading */\n.loading-container {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  height: 300px;\n  gap: var(--space-lg);\n  color: var(--text-secondary);\n}\n\n.spinner {\n  width: 40px;\n  height: 40px;\n  border: 3px solid var(--border-light);\n  border-top-color: var(--color-primary);\n  border-radius: 50%;\n  animation: spin 1s linear infinite;\n}\n\n@keyframes spin {\n  to { transform: rotate(360deg); }\n}\n\n.spin {\n  animation: spin 1s linear infinite;\n}\n\n/* Sections */\n.dashboard-section {\n  margin-bottom: var(--space-xl);\n  background: var(--bg-primary);\n  border-radius: var(--radius-lg);\n  border: 1px solid var(--border-light);\n  overflow: hidden;\n}\n\n.section-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: var(--space-lg) var(--space-xl);\n  background: var(--bg-secondary);\n  cursor: pointer;\n  transition: background var(--transition-fast);\n}\n\n.section-header:hover {\n  background: var(--bg-hover);\n}\n\n.section-title {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  font-size: var(--font-size-base);\n  font-weight: var(--font-weight-semibold);\n  color: var(--text-primary);\n}\n\n.section-toggle {\n  background: none;\n  border: none;\n  color: var(--text-secondary);\n  cursor: pointer;\n  padding: var(--space-xs);\n}\n\n/* Metrics Grid */\n.metrics-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));\n  gap: var(--space-lg);\n  padding: var(--space-xl);\n}\n\n.metric-card {\n  display: flex;\n  gap: var(--space-md);\n  padding: var(--space-lg);\n  background: var(--bg-primary);\n  border-radius: var(--radius-lg);\n  border: 1px solid var(--border-light);\n  transition: all var(--transition-fast);\n}\n\n.metric-card:hover {\n  border-color: var(--border-strong);\n  box-shadow: var(--shadow-md);\n}\n\n.metric-card.highlight {\n  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);\n  color: white;\n  border: none;\n}\n\n.metric-card.highlight .metric-label,\n.metric-card.highlight .metric-sub {\n  color: rgba(255, 255, 255, 0.8);\n}\n\n.metric-icon {\n  width: 48px;\n  height: 48px;\n  border-radius: var(--radius-md);\n  background: var(--color-primary-light);\n  color: var(--color-primary);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n}\n\n.metric-card.highlight .metric-icon {\n  background: rgba(255, 255, 255, 0.2);\n  color: white;\n}\n\n.metric-icon.warning {\n  background: rgba(245, 158, 11, 0.15);\n  color: var(--color-warning);\n}\n\n.metric-icon.success {\n  background: rgba(16, 185, 129, 0.15);\n  color: var(--color-success);\n}\n\n.metric-content {\n  flex: 1;\n  min-width: 0;\n}\n\n.metric-label {\n  font-size: var(--font-size-xs);\n  color: var(--text-secondary);\n  margin-bottom: var(--space-xs);\n}\n\n.metric-value {\n  font-size: var(--font-size-xl);\n  font-weight: var(--font-weight-bold);\n  color: var(--text-primary);\n}\n\n.metric-value .unit {\n  font-size: var(--font-size-sm);\n  font-weight: normal;\n  color: var(--text-secondary);\n}\n\n.metric-sub {\n  font-size: var(--font-size-xs);\n  color: var(--text-tertiary);\n  margin-top: var(--space-xs);\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n}\n\n/* Badges */\n.badge {\n  display: inline-flex;\n  align-items: center;\n  padding: 2px 8px;\n  border-radius: var(--radius-full);\n  font-size: var(--font-size-xs);\n  font-weight: var(--font-weight-medium);\n}\n\n.badge.lte {\n  background: rgba(16, 185, 129, 0.15);\n  color: var(--color-success);\n}\n\n.badge.nr {\n  background: rgba(139, 92, 246, 0.15);\n  color: #8b5cf6;\n}\n\n/* Trend indicators */\n.trend {\n  font-size: var(--font-size-xs);\n}\n\n.trend.success { color: var(--color-success); }\n.trend.warning { color: var(--color-warning); }\n.trend.danger { color: var(--color-error); }\n\n/* Charts Grid */\n.dashboard-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: var(--space-xl);\n  padding: var(--space-xl);\n}\n\n.chart-card {\n  background: var(--bg-primary);\n  border-radius: var(--radius-lg);\n  padding: var(--space-xl);\n  border: 1px solid var(--border-light);\n  transition: all var(--transition-fast);\n}\n\n.chart-card:hover {\n  box-shadow: var(--shadow-md);\n}\n\n.chart-card.span-2 {\n  grid-column: span 2;\n}\n\n.chart-card h3 {\n  margin: 0 0 var(--space-lg) 0;\n  font-size: var(--font-size-base);\n  font-weight: var(--font-weight-semibold);\n  color: var(--text-primary);\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n}\n\n.chart-container {\n  height: 280px;\n}\n\n/* Tables */\n.tables-container {\n  padding: var(--space-xl);\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-xl);\n}\n\n.data-table-card {\n  background: var(--bg-primary);\n  border-radius: var(--radius-lg);\n  padding: var(--space-xl);\n  border: 1px solid var(--border-light);\n}\n\n.data-table-card h3 {\n  margin: 0 0 var(--space-lg) 0;\n  font-size: var(--font-size-base);\n  font-weight: var(--font-weight-semibold);\n  color: var(--text-primary);\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n}\n\n.time-badge {\n  font-size: var(--font-size-xs);\n  font-weight: normal;\n  color: var(--text-tertiary);\n  margin-left: var(--space-sm);\n}\n\n.table-scroll {\n  overflow-x: auto;\n  margin: 0 calc(var(--space-xl) * -1);\n  padding: 0 var(--space-xl);\n}\n\n.data-table {\n  width: 100%;\n  border-collapse: collapse;\n  font-size: var(--font-size-sm);\n}\n\n.data-table th,\n.data-table td {\n  padding: var(--space-md);\n  text-align: left;\n  border-bottom: 1px solid var(--border-light);\n  white-space: nowrap;\n}\n\n.data-table th {\n  font-weight: var(--font-weight-semibold);\n  color: var(--text-secondary);\n  background: var(--bg-secondary);\n  position: sticky;\n  top: 0;\n}\n\n.data-table tr:hover {\n  background: var(--bg-hover);\n}\n\n.data-table td.highlight {\n  font-weight: var(--font-weight-semibold);\n  color: var(--color-primary);\n}\n\n.band-tag {\n  display: inline-flex;\n  align-items: center;\n  padding: 2px 8px;\n  background: var(--color-primary-light);\n  color: var(--color-primary);\n  border-radius: var(--radius-sm);\n  font-weight: var(--font-weight-medium);\n  font-size: var(--font-size-xs);\n}\n\n/* PRB Bar */\n.prb-bar-container {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n}\n\n.prb-bar {\n  height: 6px;\n  background: var(--color-primary);\n  border-radius: var(--radius-full);\n  min-width: 40px;\n  max-width: 80px;\n  transition: width var(--transition-fast);\n}\n\n.prb-bar.ul {\n  background: var(--color-warning);\n}\n\n/* Comparison Section */\n.comparison-section {\n  margin-bottom: var(--space-xl);\n  background: var(--bg-primary);\n  border-radius: var(--radius-lg);\n  border: 1px solid var(--border-light);\n  overflow: hidden;\n}\n\n.comparison-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: var(--space-xl);\n  padding: var(--space-xl);\n}\n\n.comparison-card {\n  background: var(--bg-secondary);\n  border-radius: var(--radius-lg);\n  padding: var(--space-xl);\n}\n\n.comparison-card h4 {\n  margin: 0 0 var(--space-lg) 0;\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-semibold);\n  color: var(--text-secondary);\n}\n\n.comparison-bar-item {\n  margin-bottom: var(--space-md);\n}\n\n.bar-label {\n  display: flex;\n  justify-content: space-between;\n  margin-bottom: var(--space-xs);\n  font-size: var(--font-size-xs);\n}\n\n.operator-name {\n  color: var(--text-primary);\n  font-weight: var(--font-weight-medium);\n}\n\n.bar-value {\n  color: var(--text-tertiary);\n}\n\n.bar-track {\n  height: 8px;\n  background: var(--bg-tertiary);\n  border-radius: var(--radius-full);\n  overflow: hidden;\n}\n\n.bar-fill {\n  height: 100%;\n  border-radius: var(--radius-full);\n  transition: width var(--transition-slow);\n}\n\n/* Responsive */\n@media (max-width: 1200px) {\n  .dashboard-grid {\n    grid-template-columns: repeat(2, 1fr);\n  }\n\n  .chart-card.span-2 {\n    grid-column: span 2;\n  }\n\n  .comparison-grid {\n    grid-template-columns: repeat(2, 1fr);\n  }\n}\n\n@media (max-width: 768px) {\n  .dashboard {\n    padding: var(--space-lg);\n  }\n\n  .dashboard-header {\n    flex-direction: column;\n    align-items: stretch;\n  }\n\n  .dashboard-actions {\n    justify-content: flex-start;\n  }\n\n  .metrics-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .dashboard-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .chart-card.span-2 {\n    grid-column: span 1;\n  }\n\n  .comparison-grid {\n    grid-template-columns: 1fr;\n  }\n}\n\n/* Scrollbar */\n.dashboard::-webkit-scrollbar {\n  width: 8px;\n}\n\n.dashboard::-webkit-scrollbar-track {\n  background: transparent;\n}\n\n.dashboard::-webkit-scrollbar-thumb {\n  background: var(--scrollbar-thumb);\n  border-radius: var(--radius-full);\n}\n\n.dashboard::-webkit-scrollbar-thumb:hover {\n  background: var(--scrollbar-thumb-hover);\n}\n"],["STYLE",{},"/* ============================================\n   Global Styles - Operator Agent\n   Modern chat interface styling\n   ============================================ */\n\n/* ============================================\n   CSS Variables System - Operator Agent\n   Design Tokens for consistent theming\n   ============================================ */\n\n:root {\n  /* ===== Color System - Light Mode ===== */\n  --color-primary: #667eea;\n  --color-primary-hover: #5a6fd6;\n  --color-primary-light: rgba(102, 126, 234, 0.1);\n  --color-secondary: #764ba2;\n  --color-secondary-hover: #6a4190;\n\n  /* Background Colors */\n  --bg-primary: #ffffff;\n  --bg-secondary: #f8f9fa;\n  --bg-tertiary: #f1f3f5;\n  --bg-hover: rgba(0, 0, 0, 0.04);\n  --bg-active: rgba(0, 0, 0, 0.08);\n\n  /* Text Colors */\n  --text-primary: #1a1a2e;\n  --text-secondary: #4a4a6a;\n  --text-tertiary: #8888a0;\n  --text-muted: #aaaabc;\n  --text-inverse: #ffffff;\n\n  /* Border Colors */\n  --border-light: #e8e8ec;\n  --border-default: #dddde8;\n  --border-strong: #cccce0;\n\n  /* Status Colors */\n  --color-success: #10b981;\n  --color-warning: #f59e0b;\n  --color-error: #ef4444;\n  --color-info: #3b82f6;\n\n  /* Gradient Colors */\n  --gradient-primary: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n  --gradient-hover: linear-gradient(135deg, #5a6fd6 0%, #6a4190 100%);\n  --gradient-accent: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);\n\n  /* ===== Spacing System ===== */\n  --space-xs: 4px;\n  --space-sm: 8px;\n  --space-md: 12px;\n  --space-lg: 16px;\n  --space-xl: 20px;\n  --space-2xl: 24px;\n  --space-3xl: 32px;\n\n  /* ===== Typography ===== */\n  --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen',\n    'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue',\n    sans-serif;\n  --font-mono: 'SF Mono', 'Fira Code', 'Monaco', 'Consolas', monospace;\n\n  --font-size-xs: 11px;\n  --font-size-sm: 13px;\n  --font-size-base: 15px;\n  --font-size-lg: 17px;\n  --font-size-xl: 20px;\n  --font-size-2xl: 24px;\n\n  --font-weight-normal: 400;\n  --font-weight-medium: 500;\n  --font-weight-semibold: 600;\n  --font-weight-bold: 700;\n\n  --line-height-tight: 1.25;\n  --line-height-normal: 1.5;\n  --line-height-relaxed: 1.75;\n\n  /* ===== Border Radius ===== */\n  --radius-sm: 4px;\n  --radius-md: 8px;\n  --radius-lg: 12px;\n  --radius-xl: 16px;\n  --radius-2xl: 20px;\n  --radius-full: 9999px;\n\n  /* ===== Shadows ===== */\n  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);\n  --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);\n  --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);\n  --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);\n  --shadow-glow: 0 0 20px rgba(102, 126, 234, 0.3);\n\n  /* ===== Layout ===== */\n  --sidebar-width: 280px;\n  --sidebar-collapsed-width: 0px;\n  --header-height: 56px;\n  --input-height: 56px;\n\n  /* ===== Transitions ===== */\n  --transition-fast: 150ms ease;\n  --transition-base: 200ms ease;\n  --transition-slow: 300ms ease;\n  --transition-bounce: 300ms cubic-bezier(0.34, 1.56, 0.64, 1);\n\n  /* ===== Z-Index ===== */\n  --z-dropdown: 100;\n  --z-sticky: 200;\n  --z-modal-backdrop: 300;\n  --z-modal: 400;\n  --z-tooltip: 500;\n  --z-toast: 600;\n\n  /* ===== Scrollbar ===== */\n  --scrollbar-width: 6px;\n  --scrollbar-track: transparent;\n  --scrollbar-thumb: #d1d1e0;\n  --scrollbar-thumb-hover: #b0b0c8;\n}\n\n/* ===== Dark Mode ===== */\n\n[data-theme=\"dark\"] {\n  --bg-primary: #0f0f1a;\n  --bg-secondary: #1a1a2e;\n  --bg-tertiary: #252540;\n  --bg-hover: rgba(255, 255, 255, 0.06);\n  --bg-active: rgba(255, 255, 255, 0.1);\n\n  --text-primary: #f0f0f5;\n  --text-secondary: #b0b0c8;\n  --text-tertiary: #8888a0;\n  --text-muted: #666680;\n\n  --border-light: #2a2a45;\n  --border-default: #3a3a58;\n  --border-strong: #4a4a68;\n\n  --color-primary: #7c8ff5;\n  --color-primary-hover: #8899f7;\n  --color-primary-light: rgba(124, 143, 245, 0.15);\n\n  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);\n  --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.4), 0 2px 4px -1px rgba(0, 0, 0, 0.3);\n  --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.5), 0 4px 6px -2px rgba(0, 0, 0, 0.3);\n\n  --scrollbar-thumb: #4a4a68;\n  --scrollbar-thumb-hover: #5a5a80;\n}\n\n/* ===== System Theme Detection ===== */\n\n@media (prefers-color-scheme: dark) {\n  :root:not([data-theme=\"light\"]) {\n    --bg-primary: #0f0f1a;\n    --bg-secondary: #1a1a2e;\n    --bg-tertiary: #252540;\n    --bg-hover: rgba(255, 255, 255, 0.06);\n    --bg-active: rgba(255, 255, 255, 0.1);\n\n    --text-primary: #f0f0f5;\n    --text-secondary: #b0b0c8;\n    --text-tertiary: #8888a0;\n    --text-muted: #666680;\n\n    --border-light: #2a2a45;\n    --border-default: #3a3a58;\n    --border-strong: #4a4a68;\n\n    --color-primary: #7c8ff5;\n    --color-primary-hover: #8899f7;\n    --color-primary-light: rgba(124, 143, 245, 0.15);\n\n    --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);\n    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.4), 0 2px 4px -1px rgba(0, 0, 0, 0.3);\n    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.5), 0 4px 6px -2px rgba(0, 0, 0, 0.3);\n\n    --scrollbar-thumb: #4a4a68;\n    --scrollbar-thumb-hover: #5a5a80;\n  }\n}\n\n/* ===== Reset & Base ===== */\n\n*, *::before, *::after {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nhtml {\n  font-size: 16px;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n  text-rendering: optimizeLegibility;\n}\n\nhtml, body, #root {\n  height: 100%;\n}\n\nbody {\n  font-family: var(--font-sans);\n  font-size: var(--font-size-base);\n  line-height: var(--line-height-normal);\n  color: var(--text-primary);\n  background-color: var(--bg-primary);\n  overflow: hidden;\n}\n\n/* ===== Scrollbar Styling ===== */\n\n::-webkit-scrollbar {\n  width: var(--scrollbar-width);\n  height: var(--scrollbar-width);\n}\n\n::-webkit-scrollbar-track {\n  background: var(--scrollbar-track);\n}\n\n::-webkit-scrollbar-thumb {\n  background: var(--scrollbar-thumb);\n  border-radius: var(--radius-full);\n}\n\n::-webkit-scrollbar-thumb:hover {\n  background: var(--scrollbar-thumb-hover);\n}\n\n/* ===== Selection ===== */\n\n::selection {\n  background: var(--color-primary-light);\n  color: var(--color-primary);\n}\n\n/* ===== Focus Styles ===== */\n\n:focus-visible {\n  outline: 2px solid var(--color-primary);\n  outline-offset: 2px;\n}\n\n/* ===== Links ===== */\n\na {\n  color: var(--color-primary);\n  text-decoration: none;\n  transition: color var(--transition-fast);\n}\n\na:hover {\n  color: var(--color-primary-hover);\n}\n\n/* ===== Buttons Reset ===== */\n\nbutton {\n  font-family: inherit;\n  font-size: inherit;\n  cursor: pointer;\n  border: none;\n  background: none;\n  color: inherit;\n}\n\nbutton:disabled {\n  cursor: not-allowed;\n  opacity: 0.6;\n}\n\n/* ===== Input Reset ===== */\n\ninput, textarea, select {\n  font-family: inherit;\n  font-size: inherit;\n  color: inherit;\n}\n\ninput::placeholder,\ntextarea::placeholder {\n  color: var(--text-muted);\n}\n\n/* ===== Typography ===== */\n\nh1, h2, h3, h4, h5, h6 {\n  font-weight: var(--font-weight-semibold);\n  line-height: var(--line-height-tight);\n  color: var(--text-primary);\n}\n\nh1 { font-size: var(--font-size-2xl); }\n\nh2 { font-size: var(--font-size-xl); }\n\nh3 { font-size: var(--font-size-lg); }\n\nh4 { font-size: var(--font-size-base); }\n\np {\n  line-height: var(--line-height-relaxed);\n}\n\n/* ===== Utility Classes ===== */\n\n.sr-only {\n  position: absolute;\n  width: 1px;\n  height: 1px;\n  padding: 0;\n  margin: -1px;\n  overflow: hidden;\n  clip: rect(0, 0, 0, 0);\n  white-space: nowrap;\n  border: 0;\n}\n\n.truncate {\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n\n/* ===== Animations ===== */\n\n@keyframes fadeIn {\n  from { opacity: 0; }\n  to { opacity: 1; }\n}\n\n@keyframes slideUp {\n  from {\n    opacity: 0;\n    transform: translateY(10px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n@keyframes slideDown {\n  from {\n    opacity: 0;\n    transform: translateY(-10px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n@keyframes scaleIn {\n  from {\n    opacity: 0;\n    transform: scale(0.95);\n  }\n  to {\n    opacity: 1;\n    transform: scale(1);\n  }\n}\n\n@keyframes pulse {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.5; }\n}\n\n@keyframes spin {\n  from { transform: rotate(0deg); }\n  to { transform: rotate(360deg); }\n}\n\n@keyframes shimmer {\n  0% { background-position: -200% 0; }\n  100% { background-position: 200% 0; }\n}\n\n/* ===== Toast Container ===== */\n\n.toast-container {\n  position: fixed;\n  bottom: var(--space-xl);\n  right: var(--space-xl);\n  z-index: var(--z-toast);\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-sm);\n  pointer-events: none;\n}\n\n.toast-container > * {\n  pointer-events: auto;\n}\n\n.toast {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-md) var(--space-lg);\n  background: var(--bg-secondary);\n  border: 1px solid var(--border-light);\n  border-radius: var(--radius-lg);\n  box-shadow: var(--shadow-lg);\n  animation: slideUp var(--transition-base) ease-out;\n}\n\n.toast.success {\n  border-color: var(--color-success);\n}\n\n.toast.error {\n  border-color: var(--color-error);\n}\n\n.toast.warning {\n  border-color: var(--color-warning);\n}\n\n/* ===== Modal Backdrop ===== */\n\n.modal-backdrop {\n  position: fixed;\n  inset: 0;\n  background: rgba(0, 0, 0, 0.5);\n  backdrop-filter: blur(4px);\n  z-index: var(--z-modal-backdrop);\n  animation: fadeIn var(--transition-fast) ease-out;\n}\n\n.modal {\n  position: fixed;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  z-index: var(--z-modal);\n  background: var(--bg-primary);\n  border-radius: var(--radius-xl);\n  box-shadow: var(--shadow-xl);\n  animation: scaleIn var(--transition-base) ease-out;\n  max-height: 90vh;\n  overflow-y: auto;\n}\n\n/* ===== Loading Skeleton ===== */\n\n.skeleton {\n  background: linear-gradient(\n    90deg,\n    var(--bg-tertiary) 0%,\n    var(--bg-secondary) 50%,\n    var(--bg-tertiary) 100%\n  );\n  background-size: 200% 100%;\n  animation: shimmer 1.5s infinite;\n  border-radius: var(--radius-md);\n}\n\n/* ===== Badge ===== */\n\n.badge {\n  display: inline-flex;\n  align-items: center;\n  padding: 2px 8px;\n  font-size: var(--font-size-xs);\n  font-weight: var(--font-weight-medium);\n  border-radius: var(--radius-full);\n  background: var(--color-primary-light);\n  color: var(--color-primary);\n}\n\n.badge.success {\n  background: rgba(16, 185, 129, 0.15);\n  color: var(--color-success);\n}\n\n.badge.warning {\n  background: rgba(245, 158, 11, 0.15);\n  color: var(--color-warning);\n}\n\n.badge.error {\n  background: rgba(239, 68, 68, 0.15);\n  color: var(--color-error);\n}\n\n/* ===== Dropdown ===== */\n\n.dropdown {\n  position: relative;\n  display: inline-block;\n}\n\n.dropdown-menu {\n  position: absolute;\n  top: 100%;\n  right: 0;\n  margin-top: var(--space-xs);\n  min-width: 180px;\n  background: var(--bg-primary);\n  border: 1px solid var(--border-light);\n  border-radius: var(--radius-lg);\n  box-shadow: var(--shadow-lg);\n  z-index: var(--z-dropdown);\n  animation: slideDown var(--transition-fast) ease-out;\n  overflow: hidden;\n}\n\n.dropdown-item {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-sm) var(--space-md);\n  width: 100%;\n  text-align: left;\n  transition: background var(--transition-fast);\n}\n\n.dropdown-item:hover {\n  background: var(--bg-hover);\n}\n\n.dropdown-divider {\n  height: 1px;\n  background: var(--border-light);\n  margin: var(--space-xs) 0;\n}\n\n/* ===== Tooltip ===== */\n\n.tooltip {\n  position: relative;\n}\n\n.tooltip::after {\n  content: attr(data-tooltip);\n  position: absolute;\n  bottom: 100%;\n  left: 50%;\n  transform: translateX(-50%);\n  padding: var(--space-xs) var(--space-sm);\n  background: var(--bg-tertiary);\n  color: var(--text-primary);\n  font-size: var(--font-size-xs);\n  border-radius: var(--radius-sm);\n  white-space: nowrap;\n  opacity: 0;\n  visibility: hidden;\n  transition: opacity var(--transition-fast), visibility var(--transition-fast);\n  z-index: var(--z-tooltip);\n  pointer-events: none;\n}\n\n.tooltip:hover::after {\n  opacity: 1;\n  visibility: visible;\n}\n\n/* ===== Responsive Breakpoints ===== */\n\n@media (max-width: 1024px) {\n  :root {\n    --sidebar-width: 260px;\n  }\n}\n\n@media (max-width: 768px) {\n  :root {\n    --header-height: 50px;\n  }\n\n  .toast-container {\n    left: var(--space-md);\n    right: var(--space-md);\n    bottom: var(--space-md);\n  }\n\n  .modal {\n    width: calc(100% - var(--space-xl));\n    max-width: none;\n  }\n}\n\n/* ===== App Content & Navigation ===== */\n\n.app-content {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  min-height: 0;\n  overflow: hidden;\n}\n\n.app-nav {\n  display: flex;\n  gap: var(--space-sm);\n  padding: var(--space-md) var(--space-lg);\n  background: var(--bg-primary);\n  border-top: 1px solid var(--border-light);\n  justify-content: center;\n}\n\n.nav-btn {\n  padding: var(--space-sm) var(--space-xl);\n  border: 1px solid var(--border-default);\n  border-radius: var(--radius-full);\n  background: transparent;\n  color: var(--text-secondary);\n  font-size: var(--font-size-sm);\n  font-weight: var(--font-weight-medium);\n  transition: all var(--transition-fast);\n}\n\n.nav-btn:hover {\n  background: var(--bg-hover);\n  border-color: var(--border-strong);\n  color: var(--text-primary);\n}\n\n.nav-btn.active {\n  background: var(--gradient-primary);\n  border-color: var(--color-primary);\n  color: white;\n}\n\n/* ===== Auth Login ===== */\n\n.auth-login-container {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  min-height: 100vh;\n  padding: var(--space-xl);\n  background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);\n}\n\n.auth-login-card {\n  background: var(--bg-primary);\n  padding: var(--space-3xl);\n  border-radius: var(--radius-xl);\n  box-shadow: var(--shadow-xl);\n  width: 100%;\n  max-width: 400px;\n  animation: scaleIn var(--transition-base) ease-out;\n}\n\n.auth-login-card h2 {\n  text-align: center;\n  background: var(--gradient-primary);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n  margin-bottom: var(--space-sm);\n}\n\n.auth-subtitle {\n  text-align: center;\n  color: var(--text-tertiary);\n  margin-bottom: var(--space-xl);\n  font-size: var(--font-size-sm);\n}\n\n.auth-error {\n  background: rgba(239, 68, 68, 0.1);\n  border: 1px solid rgba(239, 68, 68, 0.3);\n  color: var(--color-error);\n  padding: var(--space-md);\n  border-radius: var(--radius-md);\n  margin-bottom: var(--space-lg);\n  font-size: var(--font-size-sm);\n}\n\n.auth-form .form-group {\n  margin-bottom: var(--space-lg);\n}\n\n.auth-form label {\n  display: block;\n  margin-bottom: var(--space-sm);\n  font-weight: var(--font-weight-medium);\n  font-size: var(--font-size-sm);\n  color: var(--text-primary);\n}\n\n.auth-form input {\n  width: 100%;\n  padding: var(--space-md);\n  border: 1px solid var(--border-default);\n  border-radius: var(--radius-md);\n  font-size: var(--font-size-sm);\n  transition: all var(--transition-fast);\n}\n\n.auth-form input:focus {\n  outline: none;\n  border-color: var(--color-primary);\n  box-shadow: 0 0 0 3px var(--color-primary-light);\n}\n\n.password-input-wrapper {\n  position: relative;\n  display: flex;\n  align-items: center;\n}\n\n.password-input-wrapper input {\n  padding-right: 40px;\n}\n\n.password-toggle-btn {\n  position: absolute;\n  right: 10px;\n  background: none;\n  border: none;\n  cursor: pointer;\n  color: var(--text-secondary);\n  padding: var(--space-sm);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  transition: color var(--transition-fast);\n}\n\n.password-toggle-btn:hover {\n  color: var(--color-primary);\n}\n\n.auth-submit-btn {\n  width: 100%;\n  padding: var(--space-md);\n  background: var(--gradient-primary);\n  color: white;\n  border: none;\n  border-radius: var(--radius-md);\n  font-size: var(--font-size-base);\n  font-weight: var(--font-weight-semibold);\n  cursor: pointer;\n  transition: all var(--transition-fast);\n}\n\n.auth-submit-btn:hover:not(:disabled) {\n  opacity: 0.9;\n  transform: translateY(-1px);\n}\n\n.auth-submit-btn:disabled {\n  opacity: 0.6;\n  cursor: not-allowed;\n}\n"]],"\n  ",["BODY",{},"\n    ",["DIV",{"id":"root"},["DIV",{"class":"auth-login-container"},["DIV",{"class":"auth-login-card"},["H2",{},"OperatorBoard"],["P",{"class":"auth-subtitle"},"用户登录"],["FORM",{"class":"auth-form"},["DIV",{"class":"form-group"},["LABEL",{"for":"username"},"用户名"],["INPUT",{"__playwright_value_":"admin","type":"text","id":"username","placeholder":"请输入用户名","required":"","autocomplete":"username","value":"admin"}]],["DIV",{"class":"form-group"},["LABEL",{"for":"password"},"密码"],["DIV",{"class":"password-input-wrapper"},["INPUT",{"__playwright_value_":"admin123","type":"password","id":"password","placeholder":"请输入密码","required":"","autocomplete":"current-password","value":"admin123"}],["BUTTON",{"type":"button","class":"password-toggle-btn","tabindex":"-1"},["svg",{"xmln