@startuml 01-scenario-view
!theme plain

title 场景视图 - Scenario View

skinparam backgroundColor #FEFEFE
skinparam componentStyle rectangle

' === Actors ===
actor User as "User"
actor OperatorDashboard as "Operator Dashboard"
actor JavaNL2SQLService as "Java NL2SQL Service"
actor SQLCoder as "SQLCoder LLM"
actor MySQL as "MySQL Database"
actor OtherAgent as "Other Agent"
actor KnowledgeBase as "Knowledge Base"

' === Use Cases ===
rectangle "NL2SQL Query" {
    usecase UC001 as "UC-001 NL2SQL 自然语言查询"
    usecase UC002 as "UC-002 运营商数据查询 (CQRS)"
    usecase UC003 as "UC-003 最新频段指标查询 (CQRS)"
    usecase UC004 as "UC-004 历史频段指标查询 (CQRS)"
    usecase UC005 as "UC-005 指标趋势分析"
    usecase UC006 as "UC-006 数据看板概览"
    usecase UC007 as "UC-007 电信知识 RAG 查询"
    usecase UC008 as "UC-008 跨 Agent 数据获取"
}

' === Relationships ===
User --> UC001
User --> UC002
User --> UC003
User --> UC004
User --> UC005
User --> UC006
User --> UC007
User --> UC008

UC001 --> OperatorDashboard
UC001 --> JavaNL2SQLService
UC001 --> SQLCoder
UC001 --> MySQL

UC002 --> OperatorDashboard
UC002 --> JavaNL2SQLService
UC002 --> MySQL

UC003 --> OperatorDashboard
UC003 --> JavaNL2SQLService
UC003 --> MySQL

UC004 --> OperatorDashboard
UC004 --> JavaNL2SQLService
UC004 --> MySQL

UC005 --> OperatorDashboard
UC005 --> JavaNL2SQLService
UC005 --> MySQL

UC006 --> OperatorDashboard

UC007 --> KnowledgeBase

UC008 --> OtherAgent

@enduml
