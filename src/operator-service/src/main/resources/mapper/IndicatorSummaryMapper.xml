    <select id="findAllLatest" resultMap="IndicatorSummaryResultMap">
        SELECT i.* FROM indicator_summary i
        WHERE i.data_month = (
            SELECT MAX(i2.data_month)
            FROM indicator_summary i2
            WHERE i2.operator_id = i.operator_id
        )
        ORDER BY i.operator_id
    </select>

    <select id="findLatestByOperatorId" resultMap="IndicatorSummaryResultMap">
        SELECT i.* FROM indicator_summary i
        WHERE i.operator_id = #{operatorId}
          AND i.data_month = (
            SELECT MAX(i2.data_month)
            FROM indicator_summary i2
            WHERE i2.operator_id = #{operatorId}
        )
    </select>

    <select id="findHistoryByOperatorId" resultMap="IndicatorSummaryResultMap">
        SELECT i.* FROM indicator_summary i
        WHERE i.operator_id = #{operatorId}
        ORDER BY i.data_month DESC
    </select>

    <select id="findByDataMonth" resultMap="IndicatorSummaryResultMap">
        SELECT i.* FROM indicator_summary i
        WHERE i.data_month = #{dataMonth}
        ORDER BY i.operator_id
    </select>

    <select id="findByOperatorIdAndMonth" resultMap="IndicatorSummaryResultMap">
        SELECT i.* FROM indicator_summary i
        WHERE i.operator_id = #{operatorId}
          AND i.data_month = #{dataMonth}
    </select>

    <select id="findAllLatestMetrics" resultMap="IndicatorSummaryResultMap">
        SELECT i.* FROM indicator_summary i
